---

---

<section id="start" class="cta-section">
  <div class="container">
    <div class="rule" aria-hidden="true">
      <span class="rule-num mono">06</span>
      <span class="rule-line"></span>
      <span class="rule-tag mono">
        <span class="rule-dot"></span>
        Start in 4 minutes
      </span>
    </div>

    <div class="grid">
      <div class="copy">
        <h2>
          Your business,<br/>
          <span class="serif italic">running itself.</span>
        </h2>
        <p class="lede">
          Thirty days free. No card up front. Cancel any time, no questions.
          By the time your morning coffee is gone, your shop's already moving.
        </p>

        <div class="actions">
          <a href="#" class="cta-btn cta-btn-primary">
            Get the app
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="#" class="cta-btn cta-btn-ghost">
            Book a 15-min demo
          </a>
        </div>

        <ul class="checks">
          <li>
            <span class="check-glyph" aria-hidden="true">
              <svg width="10" height="10" viewBox="0 0 12 12" fill="none">
                <path d="M2.5 6.2l2.4 2.3L9.5 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <span class="check-label">iOS &amp; Android</span>
          </li>
          <li>
            <span class="check-glyph" aria-hidden="true">
              <svg width="10" height="10" viewBox="0 0 12 12" fill="none">
                <path d="M2.5 6.2l2.4 2.3L9.5 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <span class="check-label">No credit card</span>
          </li>
          <li>
            <span class="check-glyph" aria-hidden="true">
              <svg width="10" height="10" viewBox="0 0 12 12" fill="none">
                <path d="M2.5 6.2l2.4 2.3L9.5 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <span class="check-label">Cancel anytime</span>
          </li>
        </ul>

        <div class="trust">
          <div class="avatars" aria-hidden="true">
            <span class="av av-1">T</span>
            <span class="av av-2">V</span>
            <span class="av av-3">I</span>
            <span class="av av-4">+</span>
          </div>
          <div class="trust-text">
            <strong>1,200+ shops</strong> already running
            <span class="trust-meta">Across 30+ cities worldwide</span>
          </div>
        </div>
      </div>

      <aside class="device" aria-hidden="true">
        <div class="phone">
          <div class="phone-notch"></div>
          <div class="phone-screen">
            <div class="screen-status">
              <span class="mono">9:41</span>
              <span class="screen-pill">
                <span class="screen-pill-dot"></span>
                5 AIs
              </span>
            </div>

            <div class="screen-greet">
              <span class="screen-eyebrow mono">Good morning</span>
              <span class="screen-name">Aran</span>
            </div>

            <div class="screen-sales">
              <span class="screen-label mono">Sales today</span>
              <span class="screen-big">$2,840</span>
              <span class="screen-delta">▲ 12.4%</span>
              <svg class="screen-spark" viewBox="0 0 200 40" preserveAspectRatio="none">
                <defs>
                  <linearGradient id="ctaSparkFill" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#84cc16" stop-opacity="0.5"/>
                    <stop offset="100%" stop-color="#84cc16" stop-opacity="0"/>
                  </linearGradient>
                </defs>
                <path d="M0 32 L20 28 L40 30 L60 22 L80 24 L100 14 L120 18 L140 10 L160 14 L180 6 L200 8 L200 40 L0 40 Z" fill="url(#ctaSparkFill)"/>
                <path d="M0 32 L20 28 L40 30 L60 22 L80 24 L100 14 L120 18 L140 10 L160 14 L180 6 L200 8" fill="none" stroke="#84cc16" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>

            <div class="screen-feed">
              <div class="feed-item">
                <span class="feed-pill mono">Priced</span>
                <div class="feed-body">
                  <strong>House special $19</strong>
                  <span>Commerce AI · +$24 lift</span>
                </div>
              </div>
              <div class="feed-item">
                <span class="feed-pill mono">Reordered</span>
                <div class="feed-body">
                  <strong>4 SKUs from your top supplier</strong>
                  <span>Operations AI · ETA 9 AM</span>
                </div>
              </div>
              <div class="feed-item">
                <span class="feed-pill mono">Replied</span>
                <div class="feed-body">
                  <strong>7 customer chats</strong>
                  <span>Growth AI · in your voice</span>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="device-glow" aria-hidden="true"></div>
      </aside>
    </div>
  </div>
</section>

<style>
  .cta-section {
    position: relative;
    overflow: hidden;
    padding: 120px 0;
    color: #fff;
    background:
      radial-gradient(900px 480px at 12% 0%, rgba(132, 204, 22, 0.12), transparent 60%),
      radial-gradient(700px 420px at 100% 100%, rgba(132, 204, 22, 0.1), transparent 60%),
      linear-gradient(180deg, #0a2418 0%, #0d2e1f 50%, #103826 100%);
  }
  .cta-section::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(ellipse 80% 70% at 50% 30%, black 30%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 30%, black 30%, transparent 80%);
    pointer-events: none;
  }
  .container { position: relative; z-index: 1; }

  /* Section rule strip — consistent with other sections */
  .rule {
    display: flex;
    align-items: center;
    gap: 18px;
    margin-bottom: 64px;
  }
  .rule-num {
    font-size: 0.78rem;
    color: #84cc16;
    letter-spacing: 0.22em;
    font-weight: 600;
    flex-shrink: 0;
  }
  .rule-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg,
      rgba(132, 204, 22, 0.4) 0%,
      rgba(255, 255, 255, 0.12) 30%,
      rgba(255, 255, 255, 0.08) 100%);
  }
  .rule-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    font-size: 0.68rem;
    color: rgba(255, 255, 255, 0.78);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    flex-shrink: 0;
  }
  .rule-dot {
    width: 5px; height: 5px; border-radius: 50%;
    background: #84cc16;
    box-shadow: 0 0 0 3px rgba(132, 204, 22, 0.2);
  }

  /* Two-column split */
  .grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
    gap: 72px;
    align-items: center;
  }

  /* Copy column */
  .copy {
    display: flex;
    flex-direction: column;
    gap: 24px;
    min-width: 0;
  }
  .copy h2 {
    color: #fff;
    font-size: clamp(2.4rem, 5vw, 4rem);
    line-height: 1;
    letter-spacing: -0.04em;
    margin: 0;
  }
  .copy h2 .italic {
    color: #d9f99d;
    font-style: italic;
    font-weight: 400;
  }
  .lede {
    color: rgba(255, 255, 255, 0.72);
    font-size: 1.05rem;
    line-height: 1.6;
    max-width: 48ch;
    margin: 0;
  }

  .actions {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 4px;
  }
  .cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    height: 50px;
    padding: 0 24px;
    border-radius: 999px;
    font-size: 0.95rem;
    font-weight: 500;
    letter-spacing: -0.005em;
    white-space: nowrap;
    border: 1px solid transparent;
    transition: background 200ms var(--ease), transform 200ms var(--ease), border-color 200ms var(--ease);
  }
  .cta-btn-primary {
    background: #fff;
    color: #0a2418;
  }
  .cta-btn-primary:hover { background: #d9f99d; transform: translateY(-1px); }
  .cta-btn-ghost {
    background: transparent;
    color: #fff;
    border-color: rgba(255, 255, 255, 0.22);
  }
  .cta-btn-ghost:hover { border-color: rgba(132, 204, 22, 0.5); background: rgba(132, 204, 22, 0.06); }

  .checks {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 20px;
    list-style: none;
    margin: 4px 0 0;
    padding: 0;
  }
  .checks li {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.88rem;
  }
  .check-glyph {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: rgba(132, 204, 22, 0.16);
    color: #84cc16;
    flex-shrink: 0;
  }

  /* Trust strip */
  .trust {
    margin-top: 16px;
    padding-top: 22px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .avatars { display: flex; flex-shrink: 0; }
  .av {
    width: 32px; height: 32px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-size: 0.76rem;
    font-weight: 600;
    color: #0a2418;
    border: 2px solid #103826;
    margin-left: -8px;
    letter-spacing: -0.01em;
  }
  .av:first-child { margin-left: 0; }
  .av-1 { background: #d9f99d; }
  .av-2 { background: #fde68a; }
  .av-3 { background: #fbcfe8; }
  .av-4 { background: rgba(255, 255, 255, 0.08); color: rgba(255, 255, 255, 0.85); }
  .trust-text {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.9rem;
    line-height: 1.4;
    display: flex;
    flex-direction: column;
  }
  .trust-text strong { color: #fff; font-weight: 600; }
  .trust-meta {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.78rem;
    margin-top: 1px;
  }

  /* Device column */
  .device {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    min-width: 0;
    min-height: 580px;
  }
  .device-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 420px;
    height: 420px;
    background: radial-gradient(circle at center, rgba(132, 204, 22, 0.25), transparent 65%);
    filter: blur(80px);
    z-index: 0;
    pointer-events: none;
  }
  .phone {
    position: relative;
    z-index: 1;
    width: 280px;
    height: 580px;
    border-radius: 44px;
    background: linear-gradient(180deg, #0a2418 0%, #061a10 100%);
    border: 1px solid rgba(255, 255, 255, 0.14);
    padding: 12px;
    box-shadow:
      0 50px 100px -30px rgba(0, 0, 0, 0.6),
      inset 0 1px 0 rgba(255, 255, 255, 0.1),
      inset 0 -1px 0 rgba(0, 0, 0, 0.5);
  }
  .phone-notch {
    position: absolute;
    top: 18px;
    left: 50%;
    transform: translateX(-50%);
    width: 96px;
    height: 26px;
    border-radius: 999px;
    background: #000;
    z-index: 2;
  }
  .phone-screen {
    width: 100%;
    height: 100%;
    border-radius: 34px;
    overflow: hidden;
    padding: 54px 16px 18px;
    background:
      radial-gradient(400px 200px at 50% 0%, rgba(132, 204, 22, 0.14), transparent 70%),
      linear-gradient(180deg, #0d2e1f 0%, #103826 100%);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .screen-status {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.66rem;
    color: rgba(255, 255, 255, 0.7);
    letter-spacing: 0.04em;
  }
  .screen-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 3px 8px;
    border-radius: 999px;
    background: rgba(132, 204, 22, 0.14);
    border: 1px solid rgba(132, 204, 22, 0.3);
    color: #d9f99d;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.58rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }
  .screen-pill-dot {
    width: 5px; height: 5px; border-radius: 50%;
    background: #84cc16;
    box-shadow: 0 0 0 2px rgba(132, 204, 22, 0.3);
  }

  .screen-greet { display: flex; flex-direction: column; gap: 2px; }
  .screen-eyebrow {
    font-size: 0.58rem;
    color: rgba(255, 255, 255, 0.5);
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }
  .screen-name {
    font-size: 1.4rem;
    font-weight: 600;
    color: #fff;
    letter-spacing: -0.02em;
    line-height: 1.05;
  }

  .screen-sales {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto auto;
    column-gap: 8px;
    row-gap: 4px;
    padding: 14px 14px 0;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 14px;
    overflow: hidden;
  }
  .screen-label {
    grid-column: 1;
    font-size: 0.6rem;
    color: rgba(255, 255, 255, 0.5);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }
  .screen-big {
    grid-column: 1;
    font-size: 1.5rem;
    font-weight: 600;
    color: #fff;
    letter-spacing: -0.03em;
    line-height: 1.05;
  }
  .screen-delta {
    grid-column: 2;
    grid-row: 1 / span 2;
    align-self: center;
    font-size: 0.66rem;
    color: #d9f99d;
    background: rgba(132, 204, 22, 0.14);
    padding: 3px 8px;
    border-radius: 999px;
    font-weight: 500;
  }
  .screen-spark {
    grid-column: 1 / -1;
    width: calc(100% + 28px);
    height: 36px;
    margin: 4px -14px 0;
    display: block;
  }

  .screen-feed {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: 2px;
  }
  .feed-item {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 10px;
    align-items: start;
    padding: 8px 10px;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
  }
  .feed-pill {
    font-size: 0.54rem;
    color: #d9f99d;
    background: rgba(132, 204, 22, 0.14);
    border: 1px solid rgba(132, 204, 22, 0.28);
    padding: 3px 7px;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    align-self: center;
  }
  .feed-body {
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
  }
  .feed-body strong {
    color: #fff;
    font-size: 0.74rem;
    font-weight: 500;
    letter-spacing: -0.005em;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .feed-body span {
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.62rem;
    line-height: 1.3;
  }

  /* Responsive */
  @media (max-width: 1040px) {
    .grid { grid-template-columns: 1fr; gap: 56px; }
    .device { order: 2; }
  }
  @media (max-width: 720px) {
    .cta-section { padding: 88px 0; }
    .rule { gap: 12px; margin-bottom: 40px; }
    .actions { flex-direction: column; align-items: stretch; width: 100%; max-width: 360px; }
    .cta-btn { width: 100%; }
    .trust { flex-wrap: wrap; }
  }
  @media (max-width: 480px) {
    .cta-section { padding: 64px 0; }
    .phone { width: 240px; height: 500px; }
    .phone-screen { padding: 50px 14px 14px; }
    .screen-name { font-size: 1.25rem; }
    .screen-big { font-size: 1.3rem; }
  }
</style>
