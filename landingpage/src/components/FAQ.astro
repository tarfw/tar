---
const faqs = [
  {
    q: "Do I need a tech team to set this up?",
    a: "No. If you can use WhatsApp, you can use TAR. Most owners are running in under five minutes.",
  },
  {
    q: "Will the AI ever do something stupid with my prices?",
    a: "You set the rules. TAR shows you big moves before making them. Switch any agent to 'ask first' or one-tap undo any action.",
  },
  {
    q: "What happens if my internet drops?",
    a: "Everything keeps working. Sales, inventory, and orders run on your phone first. We sync the moment you're back online.",
  },
  {
    q: "Which devices is TAR available on?",
    a: "TAR is a mobile-first app for iOS and Android. Run your entire business from your phone — no laptop, no web dashboard needed.",
  },
  {
    q: "How is my customer data handled?",
    a: "Your data is yours. Encrypted, isolated to your business, never sold. Export everything any time.",
  },
  {
    q: "What if I want to leave?",
    a: "Cancel any time, no fees. Export your full catalog and history as CSV. We'll help you migrate if needed.",
  },
];
---

<section id="faq" class="section section-soft">
  <div class="container">
    <div class="head">
      <span class="eyebrow">FAQ</span>
      <h2>Questions, answered.</h2>
    </div>

    <div class="faqs">
      {faqs.map((f, i) => (
        <details class="faq" open={i === 0}>
          <summary>
            <span class="q">{f.q}</span>
            <span class="chev" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </summary>
          <div class="answer">
            <p>{f.a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .section-soft {
    background: var(--bg-soft);
    border-block: 1px solid var(--line);
  }
  .head {
    margin-bottom: 56px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    max-width: 720px;
  }
  @media (max-width: 720px) { .head { margin-bottom: 40px; } }
  .faqs {
    border-top: 1px solid var(--line-2);
    max-width: 820px;
  }
  .faq {
    border-bottom: 1px solid var(--line-2);
  }
  .faq summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    padding: 22px 4px;
    list-style: none;
    cursor: pointer;
    font-size: 1rem;
    font-weight: 500;
    color: var(--ink);
  }
  .faq summary::-webkit-details-marker { display: none; }
  .faq summary::marker { display: none; content: ""; }
  .q { flex: 1; }
  .chev {
    display: grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--bg);
    border: 1px solid var(--line);
    color: var(--ink-2);
    transition: transform 240ms var(--ease);
    flex-shrink: 0;
  }
  .faq[open] .chev { transform: rotate(180deg); }
  .answer {
    padding: 0 4px 24px;
  }
  .answer p {
    color: var(--ink-2);
    font-size: 0.96rem;
    line-height: 1.6;
    max-width: 68ch;
  }
  @media (max-width: 520px) {
    .faq summary { font-size: 0.95rem; padding: 20px 4px; gap: 16px; }
  }
</style>
