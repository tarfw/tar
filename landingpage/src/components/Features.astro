---
const features = [
  {
    id: "pricing",
    num: "01",
    name: "Smart Pricing",
    glyph: "💸",
    headline: "Sell more, without discounting.",
    body: "Bumps prices during the rush, eases off when it's quiet. Every minute, every product — automatically.",
    points: ["Hourly demand model", "Per-product floor & ceiling", "Event-aware boosts"],
    proof: { k: "Avg lift", v: "+$8.4k/mo" },
    preview: "pricing",
  },
  {
    id: "restock",
    num: "02",
    name: "Auto-Restock",
    glyph: "📦",
    headline: "Never run out. Never overstock.",
    body: "Reorders and balances inventory across stores so cash isn't tied up on the shelf.",
    points: ["Vendor-aware reorders", "Multi-store balancing", "Wastage forecasting"],
    proof: { k: "Stockouts", v: "−72%" },
    preview: "restock",
  },
  {
    id: "replies",
    num: "03",
    name: "Customer Replies",
    glyph: "💬",
    headline: "Answers in your tone, in seconds.",
    body: "WhatsApp, Instagram, store chats — replied to instantly, in your voice. You stay in the loop, not the inbox.",
    points: ["Trained on your shop", "Multi-language fluency", "Escalates on edge cases"],
    proof: { k: "Avg reply", v: "12 seconds" },
    preview: "replies",
  },
  {
    id: "loyalty",
    num: "04",
    name: "Reviews & Loyalty",
    glyph: "⭐",
    headline: "Turn first-timers into regulars.",
    body: "Asks happy customers for reviews. Sends birthday treats. Builds points without a single spreadsheet.",
    points: ["Review nudges", "Birthday & milestone gifts", "Auto-points, no setup"],
    proof: { k: "Repeat rate", v: "+34%" },
    preview: "loyalty",
  },
  {
    id: "roster",
    num: "05",
    name: "Smart Roster",
    glyph: "🗓️",
    headline: "Schedule staff, no spreadsheets.",
    body: "Predicts busy hours, drafts weekly rosters, and tracks attendance — so Sundays are yours again.",
    points: ["Demand-based shifts", "Leave + swap tracking", "Attendance + payroll log"],
    proof: { k: "Time saved", v: "6 hr/week" },
    preview: "roster",
  },
  {
    id: "brief",
    num: "06",
    name: "Daily Brief",
    glyph: "🌅",
    headline: "One-screen morning report.",
    body: "Yesterday's sales and anything weird. Plain English, no charts, no jargon.",
    points: ["8 am every day", "Plain language summary", "Anomalies flagged inline"],
    proof: { k: "Delivered", v: "8:00 AM daily" },
    preview: "brief",
  },
];
---

<section id="features" class="section dark">
  <div class="bg-grid" aria-hidden="true"></div>
  <div class="container">
    <div class="rule" aria-hidden="true">
      <span class="rule-num mono">02</span>
      <span class="rule-line"></span>
      <span class="rule-tag mono">
        <span class="rule-dot"></span>
        Features
      </span>
    </div>

    <header class="head">
      <div class="head-text">
        <h2>Six AIs,<br/><span class="serif italic">one shop running itself.</span></h2>
        <p class="sub">
          Toggle them on as you grow. Each one earns its keep — and shows you
          how much it earned, in plain numbers, every morning.
        </p>
      </div>
      <a href="/features" class="head-link">
        See every job
        <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </header>

    <div class="showcase" data-features-showcase>
      <ol class="rail" role="tablist" aria-label="Six AI features">
        {features.map((f, i) => (
          <li>
            <button
              type="button"
              class={`rail-btn ${i === 0 ? "is-active" : ""}`}
              role="tab"
              aria-selected={i === 0 ? "true" : "false"}
              aria-controls={`panel-${f.id}`}
              data-feature-target={f.id}
            >
              <span class="rail-num mono">{f.num}</span>
              <span class="rail-glyph" aria-hidden="true">{f.glyph}</span>
              <span class="rail-body">
                <span class="rail-name">{f.name}</span>
                <span class="rail-head">{f.headline}</span>
              </span>
              <svg class="rail-arrow" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </li>
        ))}
      </ol>

      <div class="stage">
        {features.map((f, i) => (
          <article
            id={`panel-${f.id}`}
            class={`panel ${i === 0 ? "is-active" : ""}`}
            role="tabpanel"
            data-feature-panel={f.id}
            aria-hidden={i === 0 ? "false" : "true"}
          >
            <div class="panel-head">
              <span class="panel-num mono">{f.num} · {f.name}</span>
              <span class="panel-status mono">
                <span class="status-dot"></span>
                Live
              </span>
            </div>

            <h3 class="panel-headline">{f.headline}</h3>
            <p class="panel-body">{f.body}</p>

            <ul class="panel-points">
              {f.points.map((p) => (
                <li>
                  <span class="tick" aria-hidden="true">
                    <svg width="10" height="10" viewBox="0 0 12 12" fill="none">
                      <path d="M2.5 6.2l2.4 2.3L9.5 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                  <span>{p}</span>
                </li>
              ))}
            </ul>

            <div class="preview" data-preview={f.preview}>
              {f.preview === "pricing" && (
                <div class="pv-pricing">
                  <div class="pv-row pv-row-head">
                    <span>Product</span><span>Was</span><span>Now</span><span>Lift</span>
                  </div>
                  <div class="pv-row">
                    <span class="pv-name">House Special</span>
                    <span class="pv-old">$18.00</span>
                    <span class="pv-new">$19.00</span>
                    <span class="pv-lift">+5.5%</span>
                  </div>
                  <div class="pv-row">
                    <span class="pv-name">Chef's Plate</span>
                    <span class="pv-old">$16.00</span>
                    <span class="pv-new">$16.50</span>
                    <span class="pv-lift">+3.1%</span>
                  </div>
                  <div class="pv-row">
                    <span class="pv-name">House Coffee</span>
                    <span class="pv-old">$4.00</span>
                    <span class="pv-new">$4.00</span>
                    <span class="pv-flat">held</span>
                  </div>
                </div>
              )}
              {f.preview === "restock" && (
                <div class="pv-restock">
                  {[
                    { sku: "Tomato 1kg", level: 18, eta: "Tomorrow 9 AM" },
                    { sku: "Onion 1kg", level: 42, eta: "In stock" },
                    { sku: "Fresh herbs", level: 8, eta: "Today 6 PM" },
                    { sku: "Olive oil 1L", level: 64, eta: "In stock" },
                  ].map((it) => (
                    <div class="pv-stock-row">
                      <span class="pv-stock-name">{it.sku}</span>
                      <div class="pv-bar"><span style={`width:${it.level}%`}></span></div>
                      <span class="pv-stock-eta">{it.eta}</span>
                    </div>
                  ))}
                </div>
              )}
              {f.preview === "replies" && (
                <div class="pv-replies">
                  <div class="pv-chat pv-them">
                    <span class="pv-avatar">M</span>
                    <div class="pv-bubble">Are you open tonight?</div>
                  </div>
                  <div class="pv-chat pv-us">
                    <div class="pv-bubble pv-bubble-us">Yes! Open till 11 PM. Want me to reserve a table?</div>
                  </div>
                  <div class="pv-chat pv-them">
                    <span class="pv-avatar">M</span>
                    <div class="pv-bubble">Table for 2 at 8?</div>
                  </div>
                  <div class="pv-chat pv-us">
                    <div class="pv-bubble pv-bubble-us">Done — table for 2, 8 PM tonight. See you soon!</div>
                  </div>
                  <span class="pv-meta mono">Replied in 9 seconds · in your voice</span>
                </div>
              )}
              {f.preview === "loyalty" && (
                <div class="pv-loyalty">
                  <div class="pv-event">
                    <span class="pv-pill mono">Sent</span>
                    <strong>Birthday treat → Priya R.</strong>
                    <span class="pv-event-meta">Free dessert · used in 2 days</span>
                  </div>
                  <div class="pv-event">
                    <span class="pv-pill mono">Nudged</span>
                    <strong>Review request → 14 customers</strong>
                    <span class="pv-event-meta">8 replied · 4.9 avg</span>
                  </div>
                  <div class="pv-event">
                    <span class="pv-pill mono">Earned</span>
                    <strong>+128 points across 22 visits</strong>
                    <span class="pv-event-meta">Auto-tracked, no manual log</span>
                  </div>
                </div>
              )}
              {f.preview === "roster" && (
                <div class="pv-roster">
                  <div class="pv-roster-row pv-roster-head">
                    <span></span><span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span><span>Sun</span>
                  </div>
                  {[
                    { who: "Karthik", days: ["L","L","","L","D","D","D"] },
                    { who: "Divya", days: ["D","D","D","","L","L","L"] },
                    { who: "Arun", days: ["","D","D","D","D","","L"] },
                  ].map((r) => (
                    <div class="pv-roster-row">
                      <span class="pv-roster-name">{r.who}</span>
                      {r.days.map((d) => (
                        <span class={`pv-shift ${d === "L" ? "is-l" : d === "D" ? "is-d" : "is-off"}`}>{d || "·"}</span>
                      ))}
                    </div>
                  ))}
                  <span class="pv-meta mono">Auto-drafted · demand-aware</span>
                </div>
              )}
              {f.preview === "brief" && (
                <div class="pv-brief">
                  <div class="pv-brief-head">
                    <span class="pv-time mono">Today · 8:00 AM</span>
                    <span class="pv-pill mono pv-pill-good">All good</span>
                  </div>
                  <div class="pv-brief-line">
                    <span class="pv-dot pv-dot-good"></span>
                    Yesterday's sales: <strong>$3,214</strong> (▲ 8% vs Tue avg)
                  </div>
                  <div class="pv-brief-line">
                    <span class="pv-dot pv-dot-good"></span>
                    Top mover: <strong>House Special</strong> · 38 plates
                  </div>
                  <div class="pv-brief-line">
                    <span class="pv-dot pv-dot-warn"></span>
                    Heads up: <strong>Fresh herbs low</strong> — restock by 6 PM
                  </div>
                  <div class="pv-brief-line">
                    <span class="pv-dot pv-dot-good"></span>
                    Reviews: <strong>2 new · 5 ★</strong>
                  </div>
                </div>
              )}
            </div>

            <div class="proof" aria-hidden="true">
              <span class="proof-k mono">{f.proof.k}</span>
              <span class="proof-v">{f.proof.v}</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const root = document.querySelector("[data-features-showcase]");
    if (!root) return;
    const buttons = root.querySelectorAll("[data-feature-target]");
    const panels = root.querySelectorAll("[data-feature-panel]");
    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const id = btn.getAttribute("data-feature-target");
        buttons.forEach((b) => {
          const active = b === btn;
          b.classList.toggle("is-active", active);
          b.setAttribute("aria-selected", active ? "true" : "false");
        });
        panels.forEach((p) => {
          const active = p.getAttribute("data-feature-panel") === id;
          p.classList.toggle("is-active", active);
          p.setAttribute("aria-hidden", active ? "false" : "true");
        });
      });
    });
  })();
</script>

<style>
  .dark {
    position: relative;
    color: #fff;
    overflow: hidden;
    background:
      radial-gradient(900px 480px at 85% 0%, rgba(132, 204, 22, 0.1), transparent 60%),
      radial-gradient(700px 400px at 0% 100%, rgba(132, 204, 22, 0.08), transparent 60%),
      linear-gradient(180deg, #0a2418 0%, #0d2e1f 50%, #103826 100%);
  }
  .bg-grid {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(ellipse 80% 70% at 50% 30%, black 30%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 30%, black 30%, transparent 80%);
  }
  .container { position: relative; z-index: 1; }

  .rule { display: flex; align-items: center; gap: 18px; margin-bottom: 56px; }
  .rule-num { font-size: 0.78rem; color: #84cc16; letter-spacing: 0.22em; font-weight: 600; flex-shrink: 0; }
  .rule-line {
    flex: 1; height: 1px;
    background: linear-gradient(90deg, rgba(132,204,22,0.4) 0%, rgba(255,255,255,0.12) 30%, rgba(255,255,255,0.08) 100%);
  }
  .rule-tag {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 6px 12px; border-radius: 999px;
    background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1);
    font-size: 0.68rem; color: rgba(255,255,255,0.78);
    text-transform: uppercase; letter-spacing: 0.14em; flex-shrink: 0;
  }
  .rule-dot { width: 5px; height: 5px; border-radius: 50%; background: #84cc16; box-shadow: 0 0 0 3px rgba(132,204,22,0.2); }

  .head {
    display: flex; align-items: flex-end; justify-content: space-between;
    gap: 48px; flex-wrap: wrap; margin-bottom: 56px;
  }
  .head-text { max-width: 720px; }
  .head h2 {
    color: #fff; font-size: clamp(2rem, 4.2vw, 3.2rem);
    line-height: 1.02; letter-spacing: -0.035em; margin: 0 0 18px;
  }
  .head h2 .italic { color: #d9f99d; font-style: italic; font-weight: 400; }
  .head .sub { color: rgba(255,255,255,0.7); font-size: 1rem; line-height: 1.6; max-width: 56ch; margin: 0; }
  .head-link {
    display: inline-flex; align-items: center; gap: 8px;
    color: #d9f99d; font-size: 0.92rem; font-weight: 500;
    border-bottom: 1px solid rgba(217,249,157,0.4); padding-bottom: 4px;
    transition: color 200ms var(--ease), border-color 200ms var(--ease); flex-shrink: 0;
  }
  .head-link:hover { color: #fff; border-color: rgba(255,255,255,0.6); }

  /* Showcase layout — compact, denser */
  .showcase {
    display: grid;
    grid-template-columns: minmax(0, 320px) minmax(0, 1fr);
    gap: 24px;
    align-items: start;
    padding: 8px;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 20px;
    background:
      radial-gradient(600px 280px at 100% 0%, rgba(132,204,22,0.06), transparent 60%),
      rgba(0,0,0,0.18);
    backdrop-filter: blur(10px);
  }

  .rail {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-direction: column;
    gap: 2px;
    min-width: 0;
  }
  .rail-btn {
    width: 100%;
    display: grid;
    grid-template-columns: 28px minmax(0, 1fr) auto;
    column-gap: 12px;
    align-items: center;
    padding: 12px 14px;
    text-align: left;
    color: rgba(255,255,255,0.72);
    background: transparent;
    border-radius: 10px;
    transition: background 180ms var(--ease), color 180ms var(--ease);
    position: relative;
  }
  .rail-btn:hover {
    color: #fff;
    background: rgba(255,255,255,0.03);
  }
  .rail-btn.is-active {
    color: #fff;
    background: rgba(132,204,22,0.1);
    box-shadow: inset 2px 0 0 #84cc16;
  }
  .rail-btn.is-active .rail-num { color: #84cc16; }
  .rail-btn.is-active .rail-glyph {
    background: rgba(132,204,22,0.18);
    border-color: rgba(132,204,22,0.4);
  }
  .rail-btn.is-active .rail-arrow {
    opacity: 1;
    transform: translateX(0);
    color: #d9f99d;
  }

  .rail-num {
    font-size: 0.66rem;
    letter-spacing: 0.18em;
    color: rgba(255,255,255,0.4);
    font-weight: 600;
    transition: color 180ms var(--ease);
  }
  .rail-glyph {
    display: none;
  }
  .rail-body { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .rail-name {
    color: inherit;
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: -0.005em;
    line-height: 1.25;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .rail-head {
    color: rgba(255,255,255,0.45);
    font-size: 0.74rem;
    line-height: 1.3;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .rail-arrow {
    color: rgba(255,255,255,0.25);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 180ms var(--ease), transform 180ms var(--ease), color 180ms var(--ease);
    flex-shrink: 0;
  }

  /* Stage — fixed height, grid-stacked panels (no size jump on tab switch) */
  .stage {
    position: relative;
    display: grid;
    grid-template-areas: "panel";
    border-radius: 14px;
    background:
      linear-gradient(180deg, rgba(255,255,255,0.04) 0%, rgba(255,255,255,0.015) 100%);
    border: 1px solid rgba(255,255,255,0.08);
    overflow: hidden;
    min-width: 0;
  }
  .panel {
    grid-area: panel;
    padding: 22px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    min-width: 0;
    visibility: hidden;
    opacity: 0;
    transform: translateY(6px);
    pointer-events: none;
    transition: opacity 260ms var(--ease), transform 260ms var(--ease);
  }
  .panel.is-active {
    visibility: visible;
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .preview { flex: 1; }

  .panel-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    padding-bottom: 14px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .panel-num {
    font-size: 0.66rem;
    color: rgba(255,255,255,0.5);
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .panel-status {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 3px 9px; border-radius: 999px;
    background: rgba(132,204,22,0.12); border: 1px solid rgba(132,204,22,0.28);
    font-size: 0.58rem; color: #d9f99d;
    text-transform: uppercase; letter-spacing: 0.14em;
  }
  .status-dot {
    width: 5px; height: 5px; border-radius: 50%;
    background: #84cc16; box-shadow: 0 0 0 3px rgba(132,204,22,0.25);
  }

  .panel-headline {
    color: #fff;
    font-size: 1.25rem;
    letter-spacing: -0.022em;
    line-height: 1.2;
    margin: 0;
  }
  .panel-body {
    color: rgba(255,255,255,0.68);
    font-size: 0.9rem;
    line-height: 1.55;
    margin: 0;
    max-width: 60ch;
  }
  .panel-points {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-wrap: wrap; gap: 6px 16px;
  }
  .panel-points li {
    display: inline-flex; align-items: center; gap: 7px;
    font-size: 0.8rem; color: rgba(255,255,255,0.78);
  }
  .tick {
    width: 16px; height: 16px; border-radius: 50%;
    display: grid; place-items: center;
    background: rgba(132,204,22,0.16); color: #84cc16; flex-shrink: 0;
  }

  /* Preview frame — looks like a screenshot */
  .preview {
    margin-top: 2px;
    padding: 14px 16px;
    border-radius: 12px;
    background:
      linear-gradient(180deg, rgba(0,0,0,0.32) 0%, rgba(0,0,0,0.22) 100%);
    border: 1px solid rgba(255,255,255,0.06);
    display: flex;
    flex-direction: column;
    gap: 8px;
    overflow: hidden;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.03);
  }

  /* Pricing preview */
  .pv-pricing { display: flex; flex-direction: column; gap: 0; }
  .pv-row {
    display: grid;
    grid-template-columns: 1.6fr 0.7fr 0.7fr 0.8fr;
    gap: 10px;
    padding: 8px 4px;
    align-items: center;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    font-size: 0.82rem;
    color: rgba(255,255,255,0.85);
  }
  .pv-row:last-child { border-bottom: 0; }
  .pv-row-head {
    color: rgba(255,255,255,0.4);
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.58rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    padding-bottom: 4px;
  }
  .pv-name { color: #fff; font-weight: 500; }
  .pv-old { color: rgba(255,255,255,0.4); text-decoration: line-through; }
  .pv-new { color: #fff; font-weight: 600; }
  .pv-lift {
    color: #d9f99d;
    background: rgba(132,204,22,0.12);
    border: 1px solid rgba(132,204,22,0.25);
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 0.74rem;
    text-align: center;
    font-weight: 500;
  }
  .pv-flat {
    color: rgba(255,255,255,0.5);
    font-size: 0.74rem;
    font-style: italic;
  }

  /* Restock preview */
  .pv-restock { display: flex; flex-direction: column; gap: 10px; }
  .pv-stock-row {
    display: grid;
    grid-template-columns: 1.2fr 1.6fr 1fr;
    gap: 12px;
    align-items: center;
    font-size: 0.82rem;
  }
  .pv-stock-name { color: #fff; font-weight: 500; }
  .pv-bar {
    height: 5px;
    border-radius: 999px;
    background: rgba(255,255,255,0.05);
    overflow: hidden;
  }
  .pv-bar span {
    display: block;
    height: 100%;
    background: linear-gradient(90deg, #84cc16, #d9f99d);
    border-radius: 999px;
  }
  .pv-stock-eta {
    color: rgba(255,255,255,0.55);
    font-size: 0.74rem;
