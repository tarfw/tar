---
const year = new Date().getFullYear();
const cols = [
  {
    title: "Product",
    links: ["How it works", "Features", "Pricing", "Stories", "Changelog"],
  },
  {
    title: "Industries",
    links: ["Restaurants", "Retail", "Logistics", "Services", "Salons"],
  },
  {
    title: "Resources",
    links: ["Help center", "Setup guide", "Community", "Status"],
  },
  {
    title: "Company",
    links: ["About", "Careers", "Press", "Contact"],
  },
];
---

<footer class="foot">
  <div class="foot-bg" aria-hidden="true"></div>
  <div class="container foot-inner">
    <div class="top">
      <div class="brand">
        <div class="brand-row">
          <span class="brand-mark"></span>
          <span class="name">tar</span>
        </div>
        <p class="tag">AI workers for shops, restaurants, and fleets. Run your business from your phone.</p>
        <div class="status mono">
          <span class="status-dot"></span>
          All systems operational
        </div>

        <div class="stores">
          <a href="#" class="store" aria-label="Download on the App Store">
            <svg width="14" height="16" viewBox="0 0 16 18" fill="currentColor" aria-hidden="true">
              <path d="M11.6 9.5c0-1.9 1.5-2.8 1.6-2.8-.9-1.3-2.2-1.4-2.7-1.5-1.2-.1-2.2.7-2.8.7-.6 0-1.5-.7-2.4-.7-1.3 0-2.4.7-3.1 1.9-1.3 2.3-.3 5.6.9 7.5.6.9 1.4 1.9 2.4 1.9.9 0 1.3-.6 2.5-.6s1.5.6 2.5.6c1 0 1.7-.9 2.3-1.9.7-1 1-2.1 1-2.1-.1 0-2.2-.8-2.2-3zM9.7 3.9c.5-.6.8-1.4.7-2.3-.7 0-1.6.5-2.1 1-.5.5-.9 1.4-.8 2.2.8.1 1.7-.4 2.2-.9z"/>
            </svg>
            <span class="store-text">
              <span class="store-top mono">Download on</span>
              <span class="store-name">App Store</span>
            </span>
          </a>
          <a href="#" class="store" aria-label="Get it on Google Play">
            <svg width="14" height="16" viewBox="0 0 16 18" fill="none" aria-hidden="true">
              <path d="M1 1.4v15.2c0 .5.3.9.7 1L9.4 9 1.7.4C1.3.5 1 .9 1 1.4z" fill="#84cc16"/>
              <path d="M12.4 6.1L10.3 4.9 8.5 7l1.8 1.8 2.1-1.2c.7-.4.7-1.1 0-1.5z" fill="#fff"/>
              <path d="M1.7.4l8.6 8.6 2-2L2.4.1c-.3-.1-.5-.1-.7.3z" fill="#d9f99d"/>
              <path d="M1.7 17.6L10.3 9l2 2-9.9 7.5c-.2.1-.5.2-.7.1z" fill="#84cc16" opacity=".7"/>
            </svg>
            <span class="store-text">
              <span class="store-top mono">Get it on</span>
              <span class="store-name">Google Play</span>
            </span>
          </a>
        </div>
      </div>

      <div class="cols">
        {cols.map((c) => (
          <div class="col">
            <span class="col-title mono">{c.title}</span>
            <ul>
              {c.links.map((l) => <li><a href="#">{l}</a></li>)}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <div class="big" aria-hidden="true">
      <span class="serif italic">tar.</span>
    </div>

    <div class="bottom">
      <span class="mono copy">© {year} TAR Technologies</span>
      <span class="love">
        Built with
        <svg class="heart" width="13" height="13" viewBox="0 0 16 16" aria-hidden="true">
          <path d="M8 14s-5.2-3.2-6.6-6.1C.3 5.5 1.5 3 4 3c1.5 0 2.6.8 3.3 1.9C7.9 3.8 9.1 3 10.5 3c2.5 0 3.7 2.5 2.7 4.9C13 10.8 8 14 8 14z" fill="#ff5b6e"/>
        </svg>
        by Tamils, for the world
      </span>
      <div class="legal mono">
        <a href="#">Privacy</a>
        <a href="#">Terms</a>
        <a href="#">Security</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .foot {
    position: relative;
    padding: 96px 0 36px;
    color: #fff;
    overflow: hidden;
    background: linear-gradient(180deg, #103826 0%, #0d2e1f 50%, #0a2418 100%);
  }
  @media (max-width: 880px) { .foot { padding: 72px 0 28px; } }

  .foot-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(900px 480px at 50% 0%, rgba(255, 255, 255, 0.05), transparent 70%),
      radial-gradient(600px 320px at 100% 100%, rgba(132, 204, 22, 0.12), transparent 60%),
      radial-gradient(500px 260px at 0% 100%, rgba(132, 204, 22, 0.08), transparent 60%);
  }
  .foot-bg::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.022) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.022) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(ellipse 80% 70% at 50% 30%, black 30%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 30%, black 30%, transparent 80%);
  }
  .foot-inner { position: relative; z-index: 1; }

  .top {
    display: grid;
    grid-template-columns: 1.4fr 2.6fr;
    gap: 64px;
    margin-bottom: 64px;
  }

  .brand-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
  }
  .brand-mark {
    width: 22px; height: 22px;
    border-radius: 7px;
    background: linear-gradient(135deg, #84cc16 0%, #4d7c0f 100%);
    box-shadow: 0 0 0 1px rgba(255,255,255,0.08), 0 0 12px rgba(132, 204, 22, 0.25);
  }
  .name {
    font-weight: 600;
    font-size: 1.1rem;
    letter-spacing: -0.02em;
    color: #fff;
  }
  .tag {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.94rem;
    line-height: 1.55;
    max-width: 34ch;
    margin-bottom: 22px;
  }
  .status {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 999px;
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.78);
    background: rgba(255, 255, 255, 0.04);
    margin-bottom: 24px;
  }
  .status-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: #84cc16;
    box-shadow: 0 0 0 3px rgba(132, 204, 22, 0.2);
  }

  .stores {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .store {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 14px 8px 12px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.16);
    color: #fff;
  }
  .store svg { flex-shrink: 0; }
  .store-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
    text-align: left;
  }
  .store-top {
    font-size: 0.58rem;
    color: rgba(255, 255, 255, 0.6);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .store-name {
    font-size: 0.86rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .cols {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }
  .col-title {
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: rgba(255, 255, 255, 0.5);
  }
  .col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 18px;
  }
  .col a {
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.9rem;
  }

  .big {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding: 48px 0;
    margin-bottom: 32px;
    text-align: center;
    overflow: hidden;
    line-height: 0;
  }
  .big .serif {
    font-size: clamp(6rem, 22vw, 16rem);
    line-height: 0.85;
    letter-spacing: -0.06em;
    background: linear-gradient(180deg, #ffffff 0%, #d9f99d 80%, rgba(217, 249, 157, 0.4) 100%);
    -webkit-background-clip: text;
            background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    display: inline-block;
  }

  .bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.78rem;
    gap: 16px;
    flex-wrap: wrap;
  }
  .copy { color: rgba(255, 255, 255, 0.55); }
  .love {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.82rem;
    letter-spacing: -0.005em;
  }
  .heart {
    flex-shrink: 0;
    transform-origin: center;
    animation: heartbeat 1.6s ease-in-out infinite;
    filter: drop-shadow(0 0 6px rgba(255, 91, 110, 0.45));
  }
  @keyframes heartbeat {
    0%, 100% { transform: scale(1); }
    20% { transform: scale(1.18); }
    40% { transform: scale(1); }
    60% { transform: scale(1.1); }
    80% { transform: scale(1); }
  }
  .legal { display: flex; gap: 22px; }
  .legal a { color: rgba(255, 255, 255, 0.55); }

  @media (max-width: 980px) {
    .top { grid-template-columns: 1fr; gap: 48px; margin-bottom: 48px; }
  }
  @media (max-width: 720px) {
    .cols { grid-template-columns: repeat(2, 1fr); gap: 32px; }
    .big { padding: 36px 0; margin-bottom: 24px; }
  }
  @media (max-width: 520px) {
    .cols { gap: 28px 20px; }
    .bottom { flex-direction: column; gap: 12px; align-items: flex-start; }
    .stores { width: 100%; }
    .store { flex: 1; }
  }
</style>
