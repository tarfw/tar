---

---

<section class="hero">
  <div class="container hero-inner">
    <span class="meta">
      <span class="meta-dot"></span>
      <span class="mono">1,200+ businesses on TAR</span>
    </span>

    <h1>
      Run your business<br/>
      on <span class="serif italic">autopilot.</span>
    </h1>

    <p class="lede">
      AI workers that price your menu, restock shelves, and reply to customers —
      while you focus on what you love.
    </p>

    <div class="stores">
      <a href="#" class="store" aria-label="Download on the App Store">
        <svg width="18" height="20" viewBox="0 0 16 18" fill="currentColor" aria-hidden="true">
          <path d="M11.6 9.5c0-1.9 1.5-2.8 1.6-2.8-.9-1.3-2.2-1.4-2.7-1.5-1.2-.1-2.2.7-2.8.7-.6 0-1.5-.7-2.4-.7-1.3 0-2.4.7-3.1 1.9-1.3 2.3-.3 5.6.9 7.5.6.9 1.4 1.9 2.4 1.9.9 0 1.3-.6 2.5-.6s1.5.6 2.5.6c1 0 1.7-.9 2.3-1.9.7-1 1-2.1 1-2.1-.1 0-2.2-.8-2.2-3zM9.7 3.9c.5-.6.8-1.4.7-2.3-.7 0-1.6.5-2.1 1-.5.5-.9 1.4-.8 2.2.8.1 1.7-.4 2.2-.9z"/>
        </svg>
        <span class="store-text">
          <span class="store-top mono">Download on</span>
          <span class="store-name">App Store</span>
        </span>
      </a>
      <a href="#" class="store" aria-label="Get it on Google Play">
        <svg width="18" height="20" viewBox="0 0 16 18" fill="none" aria-hidden="true">
          <path d="M1 1.4v15.2c0 .5.3.9.7 1L9.4 9 1.7.4C1.3.5 1 .9 1 1.4z" fill="#84cc16"/>
          <path d="M12.4 6.1L10.3 4.9 8.5 7l1.8 1.8 2.1-1.2c.7-.4.7-1.1 0-1.5z" fill="#fff"/>
          <path d="M1.7.4l8.6 8.6 2-2L2.4.1c-.3-.1-.5-.1-.7.3z" fill="#d9f99d"/>
          <path d="M1.7 17.6L10.3 9l2 2-9.9 7.5c-.2.1-.5.2-.7.1z" fill="#84cc16" opacity=".7"/>
        </svg>
        <span class="store-text">
          <span class="store-top mono">Get it on</span>
          <span class="store-name">Google Play</span>
        </span>
      </a>
    </div>

    <ul class="check-row">
      <li><span class="tick" aria-hidden="true">✓</span> Free 30 days</li>
      <li><span class="tick" aria-hidden="true">✓</span> 4-min setup</li>
      <li><span class="tick" aria-hidden="true">✓</span> Works offline</li>
    </ul>
  </div>
</section>

<div class="canvas-wrap">
  <div class="container canvas-container">
    <div class="phone">
      <div class="phone-frame">
        <div class="phone-island" aria-hidden="true"></div>
        <div class="phone-screen">
          <div class="ios-bar">
            <span class="ios-time mono">9:41</span>
            <span class="ios-right" aria-hidden="true">
              <svg width="16" height="10" viewBox="0 0 16 10" fill="currentColor"><rect x="0" y="6" width="2.5" height="4" rx="0.5"/><rect x="3.7" y="4" width="2.5" height="6" rx="0.5"/><rect x="7.4" y="2" width="2.5" height="8" rx="0.5"/><rect x="11.1" y="0" width="2.5" height="10" rx="0.5"/></svg>
              <svg width="13" height="10" viewBox="0 0 13 10" fill="currentColor"><path d="M6.5 1.5C4.5 1.5 2.7 2.3 1.3 3.5L0 2.2C1.7 0.8 4 0 6.5 0s4.8 0.8 6.5 2.2L11.7 3.5C10.3 2.3 8.5 1.5 6.5 1.5z"/><circle cx="6.5" cy="8" r="1.5"/></svg>
              <svg width="22" height="10" viewBox="0 0 22 10" fill="none"><rect x="0.5" y="0.5" width="18" height="9" rx="2" stroke="currentColor"/><rect x="2" y="2" width="14" height="6" rx="1" fill="currentColor"/><rect x="19.5" y="3.5" width="1.5" height="3" rx="0.5" fill="currentColor"/></svg>
            </span>
          </div>

          <div class="ios-nav">
            <span class="ios-nav-back" aria-hidden="true">
              <svg width="11" height="18" viewBox="0 0 11 18" fill="none"><path d="M9.5 1L1.5 9L9.5 17" stroke="#0a2418" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <span class="ios-nav-title">Today</span>
            <span class="ios-nav-action">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="9" stroke="#0a2418" stroke-width="1.6"/><path d="M10 6v8M6 10h8" stroke="#0a2418" stroke-width="1.6" stroke-linecap="round"/></svg>
            </span>
          </div>

          <div class="screen-body">
            <div class="greet">
              <span class="greet-eyebrow mono">Good morning</span>
              <h3 class="greet-name">Aran</h3>
              <span class="greet-pill">
                <span class="greet-dot"></span>
                <span class="mono">5 agents working</span>
              </span>
            </div>

            <article class="hero-card">
              <span class="hc-label mono">Sales today</span>
              <span class="hc-num">₹28,420</span>
              <span class="hc-delta">▲ 12.4% vs yesterday</span>
              <div class="hc-spark" aria-hidden="true">
                <svg viewBox="0 0 220 56" preserveAspectRatio="none">
                  <defs>
                    <linearGradient id="sparkFill" x1="0" y1="0" x2="0" y2="1">
                      <stop offset="0%" stop-color="#84cc16" stop-opacity="0.35"/>
                      <stop offset="100%" stop-color="#84cc16" stop-opacity="0"/>
                    </linearGradient>
                  </defs>
                  <path d="M0 42 L24 36 L48 38 L72 28 L96 30 L120 20 L144 24 L168 14 L192 18 L220 8 L220 56 L0 56 Z" fill="url(#sparkFill)"/>
                  <path d="M0 42 L24 36 L48 38 L72 28 L96 30 L120 20 L144 24 L168 14 L192 18 L220 8" fill="none" stroke="#15803d" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            </article>

            <div class="mini-row">
              <div class="mini">
                <span class="mini-k mono">Orders</span>
                <span class="mini-v">142</span>
              </div>
              <div class="mini">
                <span class="mini-k mono">Reviews</span>
                <span class="mini-v">4.8 ★</span>
              </div>
            </div>

            <section class="feed">
              <div class="feed-top">
                <span class="feed-title">Agent activity</span>
                <span class="feed-time mono">last 4h</span>
              </div>
              <ul class="feed-list">
                <li>
                  <span class="f-icon" style="background:#fff4ed;color:#c2410c">₹</span>
                  <div class="f-body">
                    <strong>Priced Biryani up to ₹190</strong>
                    <span>Lunch rush · +₹420 lift</span>
                  </div>
                </li>
                <li>
                  <span class="f-icon" style="background:#eff6ff;color:#1d4ed8">↻</span>
                  <div class="f-body">
                    <strong>Reordered 4 SKUs</strong>
                    <span>Coke · Raita · Lassi</span>
                  </div>
                </li>
                <li>
                  <span class="f-icon" style="background:#f0fdf4;color:#15803d">✓</span>
                  <div class="f-body">
                    <strong>Resolved 7 customer chats</strong>
                    <span>Avg reply 12s</span>
                  </div>
                </li>
              </ul>
            </section>
          </div>

          <div class="ios-tabs">
            <span class="tab is-active" aria-current="page">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M3 8l7-5 7 5v9H3z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
              <span class="tab-label">Home</span>
            </span>
            <span class="tab">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7" stroke="currentColor" stroke-width="1.6"/><path d="M10 6v4l3 2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
              <span class="tab-label">Activity</span>
            </span>
            <span class="tab">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><rect x="3" y="3" width="14" height="14" rx="3" stroke="currentColor" stroke-width="1.6"/><path d="M7 10h6M7 13h4M7 7h6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
              <span class="tab-label">Inbox</span>
            </span>
            <span class="tab">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="7" r="3" stroke="currentColor" stroke-width="1.6"/><path d="M3.5 17c0-3 3-5 6.5-5s6.5 2 6.5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
              <span class="tab-label">Profile</span>
            </span>
          </div>

          <div class="home-bar" aria-hidden="true"></div>
        </div>
      </div>

      <div class="phone-glow" aria-hidden="true"></div>
    </div>
  </div>
</div>

<style>
  .hero {
    padding: 88px 0 140px;
    position: relative;
    color: #fff;
    background:
      radial-gradient(900px 480px at 50% 0%, rgba(255, 255, 255, 0.06), transparent 70%),
      radial-gradient(600px 300px at 90% 90%, rgba(132, 204, 22, 0.14), transparent 60%),
      radial-gradient(500px 280px at 10% 100%, rgba(132, 204, 22, 0.08), transparent 60%),
      linear-gradient(180deg, #0a2418 0%, #0d2e1f 60%, #103826 100%);
    overflow: hidden;
  }
  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(ellipse 80% 70% at 50% 30%, black 30%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 30%, black 30%, transparent 80%);
    pointer-events: none;
  }
  :global(.hero h1) { color: #fff; }
  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0;
    position: relative;
    z-index: 1;
  }
  .hero-inner > .meta { margin-bottom: 22px; }
  .hero-inner > h1 { margin-bottom: 20px; }
  .hero-inner > .lede { margin-bottom: 32px; }
  .hero-inner > .stores { margin-bottom: 24px; }
  .meta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 6px 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.14);
    font-size: 0.74rem;
    color: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }
  .meta-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: #84cc16;
    box-shadow: 0 0 0 3px rgba(132, 204, 22, 0.25);
  }
  .hero h1 .italic {
    font-style: italic;
    font-weight: 400;
    font-size: 1.05em;
    color: #d9f99d;
  }
  .lede {
    font-size: clamp(1.05rem, 1.4vw, 1.18rem);
    color: rgba(255, 255, 255, 0.72);
    max-width: 52ch;
    line-height: 1.55;
  }

  .stores {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .store {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 10px 20px 10px 16px;
    border-radius: 14px;
    background: #fff;
    color: #0a2418;
    min-width: 168px;
  }
  .store + .store {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: #fff;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    padding: 9px 19px 9px 15px;
  }
  .store svg { flex-shrink: 0; }
  .store-text {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
    text-align: left;
  }
  .store-top {
    font-size: 0.6rem;
    color: rgba(10, 36, 24, 0.62);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .store + .store .store-top { color: rgba(255, 255, 255, 0.6); }
  .store-name {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.1;
  }

  .check-row {
    display: flex;
    flex-wrap: wrap;
    gap: 22px;
    justify-content: center;
    list-style: none;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.84rem;
  }
  .check-row li {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .tick {
    color: #84cc16;
    font-weight: 700;
    font-size: 0.78rem;
  }

  .canvas-wrap {
    position: relative;
    background: linear-gradient(180deg, #103826 0%, #103826 38%, var(--bg) 38%, var(--bg) 100%);
    padding-bottom: 0;
  }
  .canvas-container {
    display: flex;
    justify-content: center;
  }

  .phone {
    position: relative;
    width: 320px;
    transform: translateY(-110px);
    margin-bottom: -110px;
  }
  .phone-glow {
    position: absolute;
    inset: 20% -8% -8%;
    background: radial-gradient(50% 40% at 50% 50%, rgba(132, 204, 22, 0.22), transparent 70%);
    filter: blur(30px);
    z-index: -1;
  }
  .phone-frame {
    position: relative;
    border-radius: 48px;
    padding: 8px;
    background: linear-gradient(180deg, #1a1a1a 0%, #0d0d0d 100%);
    box-shadow:
      0 0 0 1.5px rgba(255, 255, 255, 0.06) inset,
      0 1px 0 rgba(255, 255, 255, 0.08) inset,
      0 50px 100px -28px rgba(8, 28, 19, 0.6),
      0 24px 48px -16px rgba(8, 28, 19, 0.35);
  }
  .phone-island {
    position: absolute;
    top: 18px;
    left: 50%;
    transform: translateX(-50%);
    width: 96px;
    height: 28px;
    border-radius: 999px;
    background: #000;
    z-index: 2;
  }
  .phone-screen {
    position: relative;
    border-radius: 40px;
    background: var(--bg);
    overflow: hidden;
    aspect-ratio: 9 / 19.5;
  }

  .ios-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 26px 8px;
    color: #0a2418;
    height: 50px;
  }
  .ios-time {
    font-size: 0.92rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .ios-right { display: inline-flex; align-items: center; gap: 6px; }

  .ios-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 18px 14px;
  }
  .ios-nav-back, .ios-nav-action {
    display: grid;
    place-items: center;
    width: 30px;
    height: 30px;
  }
  .ios-nav-title {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--ink);
  }

  .screen-body {
    padding: 4px 16px 92px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    overflow: hidden;
  }
  .greet { display: flex; flex-direction: column; gap: 4px; }
  .greet-eyebrow {
    font-size: 0.62rem;
    color: var(--ink-3);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-weight: 500;
  }
  .greet-name {
    font-size: 1.55rem;
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.05;
  }
  .greet-pill {
    align-self: flex-start;
    margin-top: 8px;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 4px 10px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--bg-soft);
    font-size: 0.68rem;
    color: var(--ink-2);
  }
  .greet-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--good);
    box-shadow: 0 0 0 2.5px rgba(21, 128, 61, 0.18);
  }

  .hero-card {
    border: 1px solid var(--line);
    border-radius: 18px;
    padding: 18px 18px 8px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    background:
      radial-gradient(120% 60% at 100% 0%, rgba(132, 204, 22, 0.12), transparent 60%),
      var(--bg);
    overflow: hidden;
  }
  .hc-label {
    font-size: 0.62rem;
    color: var(--ink-3);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }
  .hc-num {
    font-size: 1.85rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--ink);
    line-height: 1.05;
  }
  .hc-delta {
    font-size: 0.74rem;
    color: var(--good);
    font-weight: 500;
  }
  .hc-spark {
    margin: 6px -18px -8px;
    height: 56px;
  }
  .hc-spark svg { width: 100%; height: 100%; display: block; }

  .mini-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .mini {
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 12px 14px;
    background: var(--bg-soft);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .mini-k {
    font-size: 0.6rem;
    color: var(--ink-3);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }
  .mini-v {
    font-size: 1.15rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--ink);
  }

  .feed {
    border: 1px solid var(--line);
    border-radius: 16px;
    overflow: hidden;
    background: var(--bg);
  }
  .feed-top {
    padding: 12px 14px 10px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--line);
    background: var(--bg-soft);
  }
  .feed-title {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--ink);
  }
  .feed-time {
    font-size: 0.62rem;
    color: var(--ink-3);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .feed-list { list-style: none; }
  .feed-list li {
    display: grid;
    grid-template-columns: 30px 1fr;
    gap: 12px;
    align-items: center;
    padding: 10px 14px;
    border-bottom: 1px solid var(--line);
  }
  .feed-list li:last-child { border-bottom: 0; }
  .f-icon {
    width: 30px; height: 30px;
    border-radius: 9px;
    display: grid;
    place-items: center;
    font-size: 0.85rem;
    font-weight: 600;
  }
  .f-body { display: flex; flex-direction: column; gap: 1px; min-width: 0; }
  .f-body strong {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.25;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .f-body span {
    font-size: 0.68rem;
    color: var(--ink-3);
    line-height: 1.3;
  }

  .ios-tabs {
    position: absolute;
    bottom: 0;
    left: 0; right: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    padding: 10px 8px 22px;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-top: 1px solid var(--line);
  }
  .tab {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    padding: 4px 0;
    color: var(--ink-4);
  }
  .tab.is-active { color: #0a2418; }
  .tab-label {
    font-size: 0.58rem;
    font-weight: 500;
    letter-spacing: -0.005em;
  }
  .home-bar {
    position: absolute;
    bottom: 8px;
    left: 50%;
    transform: translateX(-50%);
    width: 110px;
    height: 4px;
    border-radius: 999px;
    background: #0a2418;
    z-index: 3;
  }

  @media (max-width: 720px) {
    .hero { padding: 56px 0 110px; }
    .hero-inner > .meta { margin-bottom: 18px; }
    .hero-inner > h1 { margin-bottom: 16px; }
    .hero-inner > .lede { margin-bottom: 26px; }
    .hero-inner > .stores { margin-bottom: 20px; }
    .canvas-wrap { background: linear-gradient(180deg, #103826 0%, #103826 30%, var(--bg) 30%, var(--bg) 100%); }
    .phone { width: 280px; transform: translateY(-80px); margin-bottom: -80px; }
    .stores { gap: 10px; }
    .store { min-width: 0; }
  }
  @media (max-width: 480px) {
    .hero h1 { font-size: clamp(2rem, 9vw, 2.4rem); }
    .lede { font-size: 0.98rem; }
    .check-row { gap: 14px; font-size: 0.8rem; }
    .stores { flex-direction: column; align-items: stretch; width: 100%; max-width: 280px; }
    .store, .store + .store { padding: 11px 18px 11px 16px; justify-content: flex-start; }
    .phone { width: min(260px, 78vw); transform: translateY(-60px); margin-bottom: -60px; }
    .canvas-wrap { background: linear-gradient(180deg, #103826 0%, #103826 22%, var(--bg) 22%, var(--bg) 100%); }
    .ios-bar { padding: 12px 22px 6px; }
    .ios-nav { padding: 6px 16px 12px; }
    .screen-body { padding: 4px 14px 86px; gap: 12px; }
    .hc-num { font-size: 1.6rem; }
    .greet-name { font-size: 1.35rem; }
  }
</style>
