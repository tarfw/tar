---
const highlights = [
  { k: "Setup", v: "4 min" },
  { k: "Saves", v: "6 hr / wk" },
  { k: "Replies", v: "12s avg" },
  { k: "Trial", v: "Free 30 days" },
];

const liveFeed = [
  {
    glyph: "🛍️",
    pill: "Priced",
    title: "House special up to $4.90",
    meta: "Commerce AI · +$24 lift",
    delay: 0,
  },
  {
    glyph: "🚚",
    pill: "Reordered",
    title: "4 SKUs from your top supplier",
    meta: "Operations AI · ETA tomorrow 9 AM",
    delay: 120,
  },
  {
    glyph: "📢",
    pill: "Replied",
    title: "7 customer chats resolved",
    meta: "Growth AI · in your voice",
    delay: 240,
  },
];
---

<section class="hero">
  <div class="bg-grid" aria-hidden="true"></div>
  <div class="bg-glow" aria-hidden="true"></div>

  <div class="container">
    <div class="rule" aria-hidden="true">
      <span class="rule-num mono">00</span>
      <span class="rule-line"></span>
      <span class="rule-tag mono">
        <span class="rule-dot"></span>
        Run your business with AI
      </span>
    </div>

    <div class="grid">
      <div class="lede-col">
        <span class="badge">
          <span class="badge-dot"></span>
          <span class="mono">1,200+ businesses on TAR</span>
        </span>

        <h1>
          Six <span class="serif italic">AIs.</span><br/>
          One business<br/>
          <span class="serif italic">running itself.</span>
        </h1>

        <p class="lede">
          TAR puts six AIs to work in your shop, restaurant or fleet — pricing,
          restock, replies, rosters, payments, storefront. You set the rules,
          they handle the day.
        </p>

        <div class="stores">
          <a href="#start" class="store store-primary" aria-label="Download on the App Store">
            <svg width="18" height="20" viewBox="0 0 16 18" fill="currentColor" aria-hidden="true">
              <path d="M11.6 9.5c0-1.9 1.5-2.8 1.6-2.8-.9-1.3-2.2-1.4-2.7-1.5-1.2-.1-2.2.7-2.8.7-.6 0-1.5-.7-2.4-.7-1.3 0-2.4.7-3.1 1.9-1.3 2.3-.3 5.6.9 7.5.6.9 1.4 1.9 2.4 1.9.9 0 1.3-.6 2.5-.6s1.5.6 2.5.6c1 0 1.7-.9 2.3-1.9.7-1 1-2.1 1-2.1-.1 0-2.2-.8-2.2-3zM9.7 3.9c.5-.6.8-1.4.7-2.3-.7 0-1.6.5-2.1 1-.5.5-.9 1.4-.8 2.2.8.1 1.7-.4 2.2-.9z"/>
            </svg>
            <span class="store-text">
              <span class="store-top mono">Download on</span>
              <span class="store-name">App Store</span>
            </span>
          </a>
          <a href="#start" class="store" aria-label="Get it on Google Play">
            <svg width="18" height="20" viewBox="0 0 16 18" fill="none" aria-hidden="true">
              <path d="M1 1.4v15.2c0 .5.3.9.7 1L9.4 9 1.7.4C1.3.5 1 .9 1 1.4z" fill="#84cc16"/>
              <path d="M12.4 6.1L10.3 4.9 8.5 7l1.8 1.8 2.1-1.2c.7-.4.7-1.1 0-1.5z" fill="#fff"/>
              <path d="M1.7.4l8.6 8.6 2-2L2.4.1c-.3-.1-.5-.1-.7.3z" fill="#d9f99d"/>
              <path d="M1.7 17.6L10.3 9l2 2-9.9 7.5c-.2.1-.5.2-.7.1z" fill="#84cc16" opacity=".7"/>
            </svg>
            <span class="store-text">
              <span class="store-top mono">Get it on</span>
              <span class="store-name">Google Play</span>
            </span>
          </a>
        </div>

        <dl class="stats">
          {highlights.map((h) => (
            <div>
              <dt class="mono">{h.k}</dt>
              <dd>{h.v}</dd>
            </div>
          ))}
        </dl>
      </div>

      <div class="canvas-col">
        <div class="canvas-card" aria-label="TAR app preview">
          <div class="canvas-head">
            <div class="dots" aria-hidden="true">
              <span></span><span></span><span></span>
            </div>
            <span class="canvas-title mono">tar · today</span>
            <span class="canvas-status">
              <span class="status-dot"></span>
              live
            </span>
          </div>

          <div class="canvas-greet">
            <div class="greet-text">
              <span class="greet-eyebrow mono">Good morning</span>
              <span class="greet-name">Aran</span>
            </div>
            <span class="greet-pill mono">
              <span class="greet-dot"></span>
              5 AIs working
            </span>
          </div>

          <article class="sales">
            <div class="sales-head">
              <span class="sales-label mono">Sales today</span>
              <span class="sales-delta">▲ 12.4%</span>
            </div>
            <div class="sales-num">$2,840</div>
            <div class="sales-spark" aria-hidden="true">
              <svg viewBox="0 0 320 64" preserveAspectRatio="none">
                <defs>
                  <linearGradient id="heroSparkFill" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#84cc16" stop-opacity="0.45"/>
                    <stop offset="100%" stop-color="#84cc16" stop-opacity="0"/>
                  </linearGradient>
                </defs>
                <path d="M0 50 L32 42 L64 46 L96 32 L128 38 L160 22 L192 30 L224 16 L256 22 L288 8 L320 12 L320 64 L0 64 Z" fill="url(#heroSparkFill)"/>
                <path d="M0 50 L32 42 L64 46 L96 32 L128 38 L160 22 L192 30 L224 16 L256 22 L288 8 L320 12" fill="none" stroke="#84cc16" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </article>

          <div class="kpis">
            <div class="kpi">
              <span class="kpi-k mono">Orders</span>
              <span class="kpi-v">142</span>
            </div>
            <div class="kpi">
              <span class="kpi-k mono">Reviews</span>
              <span class="kpi-v">4.8 ★</span>
            </div>
            <div class="kpi">
              <span class="kpi-k mono">Repeat</span>
              <span class="kpi-v">68%</span>
            </div>
          </div>

          <div class="feed">
            <div class="feed-head">
              <span class="feed-title">AI activity · last 4h</span>
              <span class="feed-tag mono">3 events</span>
            </div>
            <ul>
              {liveFeed.map((f) => (
                <li style={`--d:${f.delay}ms`}>
                  <span class="f-glyph" aria-hidden="true">{f.glyph}</span>
                  <div class="f-body">
                    <div class="f-line">
                      <span class="f-pill mono">{f.pill}</span>
                      <strong>{f.title}</strong>
                    </div>
                    <span class="f-meta">{f.meta}</span>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    color: #fff;
    padding: 96px 0 120px;
    background:
      radial-gradient(900px 480px at 90% 0%, rgba(132, 204, 22, 0.14), transparent 60%),
      radial-gradient(600px 400px at 0% 100%, rgba(132, 204, 22, 0.08), transparent 60%),
      linear-gradient(180deg, #0a2418 0%, #0d2e1f 60%, #103826 100%);
  }
  .bg-grid {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(ellipse 80% 70% at 50% 30%, black 30%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 30%, black 30%, transparent 80%);
  }
  .bg-glow {
    position: absolute;
    right: -10%;
    top: 12%;
    width: 520px;
    height: 520px;
    background: radial-gradient(circle at center, rgba(132, 204, 22, 0.22), transparent 60%);
    filter: blur(60px);
    pointer-events: none;
  }
  .container { position: relative; z-index: 1; }

  /* Top rule — same vocabulary as features page */
  .rule {
    display: flex;
    align-items: center;
    gap: 18px;
    margin-bottom: 56px;
  }
  .rule-num {
    font-size: 0.78rem;
    color: #84cc16;
    letter-spacing: 0.22em;
    font-weight: 600;
    flex-shrink: 0;
  }
  .rule-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg,
      rgba(132, 204, 22, 0.4) 0%,
      rgba(255, 255, 255, 0.12) 30%,
      rgba(255, 255, 255, 0.08) 100%);
  }
  .rule-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    font-size: 0.68rem;
    color: rgba(255, 255, 255, 0.78);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    flex-shrink: 0;
  }
  .rule-dot {
    width: 5px; height: 5px; border-radius: 50%;
    background: #84cc16;
    box-shadow: 0 0 0 3px rgba(132, 204, 22, 0.2);
  }

  /* Two-column layout */
  .grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
    gap: 72px;
    align-items: start;
  }

  /* Left column */
  .lede-col {
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding-top: 8px;
  }
  .badge {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 6px 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .badge-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: #84cc16;
    box-shadow: 0 0 0 3px rgba(132, 204, 22, 0.25);
    animation: pulse 1.8s ease-in-out infinite;
  }
  @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.55; } }

  .hero h1 {
    color: #fff;
    font-size: clamp(2.6rem, 5.4vw, 4.4rem);
    line-height: 1;
    letter-spacing: -0.04em;
    margin: 0;
  }
  .hero h1 .italic {
    font-style: italic;
    font-weight: 400;
    color: #d9f99d;
    font-size: 1.05em;
  }

  .lede {
    color: rgba(255, 255, 255, 0.72);
    font-size: clamp(1rem, 1.3vw, 1.12rem);
    line-height: 1.6;
    max-width: 46ch;
    margin: 0;
  }

  .stores {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 8px;
  }
  .store {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 10px 22px 10px 16px;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.14);
    color: #fff;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    transition: background 200ms var(--ease), border-color 200ms var(--ease);
  }
  .store:hover { background: rgba(255, 255, 255, 0.1); border-color: rgba(132, 204, 22, 0.35); }
  .store-primary {
    background: #fff;
    color: #0a2418;
    border-color: transparent;
  }
  .store-primary:hover { background: #f5f3ee; }
  .store-text {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
    text-align: left;
  }
  .store-top {
    font-size: 0.6rem;
    color: rgba(255, 255, 255, 0.6);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .store-primary .store-top { color: rgba(10, 36, 24, 0.6); }
  .store-name {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.1;
  }

  /* Stats strip — case-tile grid pattern */
  .stats {
    margin-top: 12px;
    padding-top: 28px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0;
    border-left: 1px solid rgba(255, 255, 255, 0.06);
  }
  .stats > div {
    padding: 14px 16px;
    border-right: 1px solid rgba(255, 255, 255, 0.06);
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }
  .stats dt {
    font-size: 0.62rem;
    color: rgba(255, 255, 255, 0.5);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin: 0;
  }
  .stats dd {
    color: #fff;
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    margin: 0;
  }

  /* Right column — orchestration-style card */
  .canvas-col { display: flex; justify-content: center; }
  .canvas-card {
    width: 100%;
    max-width: 480px;
    background:
      radial-gradient(600px 300px at 90% -10%, rgba(132, 204, 22, 0.08), transparent 60%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.04) 0%, rgba(255, 255, 255, 0.02) 100%);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    overflow: hidden;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow:
      0 40px 80px -36px rgba(0, 0, 0, 0.55),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }
  .canvas-head {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.02);
  }
  .dots { display: flex; gap: 6px; }
  .dots span {
    width: 10px; height: 10px; border-radius: 50%;
    background: rgba(255, 255, 255, 0.18);
  }
  .canvas-title {
    flex: 1;
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.55);
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .canvas-status {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 4px 10px;
    border-radius: 999px;
    background: rgba(132, 204, 22, 0.12);
    border: 1px solid rgba(132, 204, 22, 0.28);
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.62rem;
    color: #d9f99d;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }
  .status-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: #84cc16;
    box-shadow: 0 0 0 3px rgba(132, 204, 22, 0.25);
    animation: pulse 1.8s ease-in-out infinite;
  }

  .canvas-greet {
    padding: 22px 22px 14px;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 12px;
  }
  .greet-text { display: flex; flex-direction: column; gap: 2px; }
  .greet-eyebrow {
    font-size: 0.62rem;
    color: rgba(255, 255, 255, 0.5);
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }
  .greet-name {
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.025em;
    color: #fff;
    line-height: 1.05;
  }
  .greet-pill {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 4px 10px;
    border-radius: 999px;
    background: rgba(132, 204, 22, 0.12);
    border: 1px solid rgba(132, 204, 22, 0.28);
    font-size: 0.66rem;
    color: #d9f99d;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .greet-dot {
    width: 5px; height: 5px; border-radius: 50%;
    background: #84cc16;
    box-shadow: 0 0 0 3px rgba(132, 204, 22, 0.25);
  }

  .sales {
    margin: 0 22px;
    padding: 18px 18px 0;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 14px;
    overflow: hidden;
  }
  .sales-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 6px;
  }
  .sales-label {
    font-size: 0.66rem;
    color: rgba(255, 255, 255, 0.55);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }
  .sales-delta {
    font-size: 0.76rem;
    color: #d9f99d;
    font-weight: 500;
    background: rgba(132, 204, 22, 0.12);
    padding: 2px 8px;
    border-radius: 999px;
  }
  .sales-num {
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    color: #fff;
    line-height: 1.05;
  }
  .sales-spark {
    height: 64px;
    margin: 6px -18px 0;
  }
  .sales-spark svg { width: 100%; height: 100%; display: block; }

  .kpis {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    margin: 14px 22px 0;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    overflow: hidden;
  }
  .kpi {
    padding: 12px 14px;
    border-right: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    flex-direction: column;
    gap: 2px;
    background: rgba(255, 255, 255, 0.02);
  }
  .kpi:last-child { border-right: 0; }
  .kpi-k {
    font-size: 0.6rem;
    color: rgba(255, 255, 255, 0.5);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }
  .kpi-v {
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: #fff;
  }

  .feed {
    margin: 18px 0 0;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }
  .feed-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 22px 8px;
  }
  .feed-title {
    font-size: 0.74rem;
    color: rgba(255, 255, 255, 0.7);
    font-weight: 500;
    letter-spacing: -0.005em;
  }
  .feed-tag {
    font-size: 0.62rem;
    color: rgba(255, 255, 255, 0.5);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }
  .feed ul {
    list-style: none;
    margin: 0;
    padding: 0 14px 18px;
  }
  .feed li {
    display: grid;
    grid-template-columns: 32px 1fr;
    gap: 12px;
    align-items: start;
    padding: 10px 8px;
    border-radius: 10px;
    opacity: 0;
    transform: translateY(6px);
    animation: rise 520ms var(--ease) forwards;
    animation-delay: var(--d, 0ms);
    transition: background 220ms var(--ease);
  }
  .feed li:hover { background: rgba(132, 204, 22, 0.05); }
  @keyframes rise { to { opacity: 1; transform: translateY(0); } }

  .f-glyph {
    width: 32px; height: 32px;
    border-radius: 10px;
    display: grid;
    place-items: center;
    background: rgba(132, 204, 22, 0.12);
    border: 1px solid rgba(132, 204, 22, 0.25);
    font-size: 1rem;
  }
  .f-body { display: flex; flex-direction: column; gap: 3px; min-width: 0; }
  .f-line { display: flex; align-items: center; gap: 8px; min-width: 0; }
  .f-pill {
    font-size: 0.6rem;
    color: #d9f99d;
    background: rgba(132, 204, 22, 0.14);
    border: 1px solid rgba(132, 204, 22, 0.28);
    padding: 2px 7px;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    flex-shrink: 0;
  }
  .f-body strong {
    color: #fff;
    font-size: 0.84rem;
    font-weight: 500;
    letter-spacing: -0.005em;
    line-height: 1.3;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .f-meta {
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.72rem;
    line-height: 1.3;
    padding-left: 0;
  }

  /* Responsive */
  @media (max-width: 1040px) {
    .grid {
      grid-template-columns: 1fr;
      gap: 56px;
    }
    .canvas-card { max-width: 540px; margin: 0 auto; }
  }
  @media (max-width: 720px) {
    .hero { padding: 72px 0 88px; }
    .rule { gap: 12px; margin-bottom: 36px; }
    .stats { grid-template-columns: repeat(2, 1fr); }
    .stats > div:nth-child(2) { border-right: 0; }
  }
  @media (max-width: 480px) {
    .rule-tag { display: none; }
    .stores { flex-direction: column; align-items: stretch; }
    .canvas-head { padding: 12px 16px; }
    .canvas-greet { padding: 18px 16px 12px; }
    .sales { margin: 0 16px; }
    .kpis { margin: 12px 16px 0; }
    .feed-head { padding: 14px 18px 8px; }
    .feed ul { padding: 0 12px 16px; }
    .f-body strong { white-space: normal; }
    .sales-num { font-size: 1.75rem; }
  }
</style>
