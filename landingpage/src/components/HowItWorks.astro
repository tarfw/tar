---
const steps = [
  {
    n: "01",
    name: "Connect",
    headline: "Connect what you have.",
    body: "Snap photos, import a CSV, or scan barcodes. TAR builds your catalog in minutes.",
    points: ["Photo + barcode import", "CSV from any POS", "No data team needed"],
    outcome: "182 products imported in 4 minutes",
  },
  {
    n: "02",
    name: "Activate",
    headline: "Pick your AIs.",
    body: "Choose the AI workers you want — pricing, restock, support, marketing. Toggle any time.",
    points: ["Six AIs to choose from", "Turn on or off in a tap", "Approval rules you set"],
    outcome: "5 AIs running across your shop",
  },
  {
    n: "03",
    name: "Run",
    headline: "Watch them run your shop.",
    body: "Your AIs work 24/7. You approve big moves; they handle everything else.",
    points: ["24/7 autonomous run", "You approve big moves", "Daily brief at 8 am"],
    outcome: "+$24 lift in the first hour",
  },
];
---

<section id="how" class="section light">
  <div class="bg-grid" aria-hidden="true"></div>
  <div class="container">
    <div class="rule" aria-hidden="true">
      <span class="rule-num mono">01</span>
      <span class="rule-line"></span>
      <span class="rule-tag mono">
        <span class="rule-dot"></span>
        How it works
      </span>
    </div>

    <header class="head">
      <div class="head-text">
        <h2>
          From your phone<br/>
          to a working business<br/>
          <span class="serif italic">in under 5 minutes.</span>
        </h2>
        <p class="sub">
          Three steps. No tech team, no migration weekend, no surprise bills.
          Most owners are running before their morning coffee goes cold.
        </p>
      </div>
      <a href="#start" class="head-link">
        Start free
        <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </header>

    <ol class="steps">
      {steps.map((s, i) => (
        <li class="step" style={`--d:${i * 80}ms`}>
          <div class="step-rule" aria-hidden="true">
            <span class="step-num mono">{s.n}</span>
            <span class="step-line"></span>
            <span class="step-name mono">{s.name}</span>
          </div>

          <h3>{s.headline}</h3>
          <p class="body">{s.body}</p>

          <ul class="points">
            {s.points.map((p) => (
              <li>
                <span class="tick" aria-hidden="true">
                  <svg width="10" height="10" viewBox="0 0 12 12" fill="none">
                    <path d="M2.5 6.2l2.4 2.3L9.5 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
                <span>{p}</span>
              </li>
            ))}
          </ul>

          <p class="outcome">{s.outcome}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .light {
    position: relative;
    color: #1a1a1a;
    overflow: hidden;
    background:
      radial-gradient(900px 480px at 15% 0%, rgba(132, 204, 22, 0.08), transparent 60%),
      radial-gradient(700px 400px at 100% 100%, rgba(132, 204, 22, 0.06), transparent 60%),
      linear-gradient(180deg, #ffffff 0%, #fbfaf7 100%);
  }
  .bg-grid {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(rgba(26, 26, 26, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(26, 26, 26, 0.04) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(ellipse 80% 70% at 50% 30%, black 30%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 30%, black 30%, transparent 80%);
  }
  .container { position: relative; z-index: 1; }

  /* Section rule strip */
  .rule {
    display: flex;
    align-items: center;
    gap: 18px;
    margin-bottom: 56px;
  }
  .rule-num {
    font-size: 0.78rem;
    color: #4d7c0f;
    letter-spacing: 0.22em;
    font-weight: 600;
    flex-shrink: 0;
  }
  .rule-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg,
      rgba(132, 204, 22, 0.5) 0%,
      rgba(26, 26, 26, 0.14) 30%,
      rgba(26, 26, 26, 0.08) 100%);
  }
  .rule-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    border-radius: 999px;
    background: rgba(132, 204, 22, 0.08);
    border: 1px solid rgba(132, 204, 22, 0.25);
    font-size: 0.68rem;
    color: #4d7c0f;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    flex-shrink: 0;
  }
  .rule-dot {
    width: 5px; height: 5px; border-radius: 50%;
    background: #84cc16;
    box-shadow: 0 0 0 3px rgba(132, 204, 22, 0.2);
  }

  /* Header */
  .head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 48px;
    flex-wrap: wrap;
    margin-bottom: 72px;
  }
  .head-text { max-width: 720px; }
  .head h2 {
    color: #1a1a1a;
    font-size: clamp(2rem, 4.2vw, 3.2rem);
    line-height: 1.02;
    letter-spacing: -0.035em;
    margin: 0 0 18px;
  }
  .head h2 .italic {
    color: #4d7c0f;
    font-style: italic;
    font-weight: 400;
  }
  .head .sub {
    color: #555555;
    font-size: 1rem;
    line-height: 1.6;
    max-width: 56ch;
    margin: 0;
  }
  .head-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #4d7c0f;
    font-size: 0.92rem;
    font-weight: 500;
    border-bottom: 1px solid rgba(77, 124, 15, 0.4);
    padding-bottom: 4px;
    transition: color 200ms var(--ease), border-color 200ms var(--ease);
    flex-shrink: 0;
  }
  .head-link:hover {
    color: #1a1a1a;
    border-color: #1a1a1a;
  }

  /* Three flat columns */
  .steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 48px;
  }
  .step {
    display: flex;
    flex-direction: column;
    gap: 16px;
    opacity: 0;
    transform: translateY(10px);
    animation: rise 540ms var(--ease) forwards;
    animation-delay: var(--d, 0ms);
  }
  @keyframes rise { to { opacity: 1; transform: translateY(0); } }

  /* Top rule per step — mirrors the section rule */
  .step-rule {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-bottom: 18px;
    border-bottom: 1px solid rgba(26, 26, 26, 0.1);
  }
  .step-num {
    font-size: 0.78rem;
    color: #4d7c0f;
    letter-spacing: 0.2em;
    font-weight: 600;
    flex-shrink: 0;
  }
  .step-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, rgba(132, 204, 22, 0.35), rgba(26, 26, 26, 0.08));
  }
  .step-name {
    font-size: 0.68rem;
    color: #555555;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 500;
    flex-shrink: 0;
  }

  .step h3 {
    color: #1a1a1a;
    font-size: 1.35rem;
    letter-spacing: -0.025em;
    line-height: 1.2;
    margin: 0;
  }
  .step .body {
    color: #555555;
    font-size: 0.95rem;
    line-height: 1.55;
    margin: 0;
  }

  .points {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 9px;
  }
  .points li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.88rem;
    color: #1a1a1a;
    line-height: 1.45;
  }
  .tick {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: rgba(132, 204, 22, 0.16);
    color: #4d7c0f;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .outcome {
    margin: 8px 0 0;
    padding-top: 16px;
    border-top: 1px solid rgba(26, 26, 26, 0.08);
    color: #4d7c0f;
    font-size: 0.88rem;
    line-height: 1.45;
    font-weight: 600;
    letter-spacing: -0.005em;
  }

  @media (max-width: 880px) {
    .head { margin-bottom: 48px; }
    .steps { grid-template-columns: 1fr; gap: 40px; }
  }
  @media (max-width: 600px) {
    .rule { gap: 12px; margin-bottom: 36px; }
  }
</style>
