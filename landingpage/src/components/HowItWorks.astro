---
const steps = [
  {
    n: "01",
    name: "Connect",
    headline: "Connect what you have.",
    body: "Snap photos, import a CSV, or scan barcodes. TAR builds your catalog in minutes.",
    points: ["Photo + barcode import", "CSV from any POS", "No data team needed"],
  },
  {
    n: "02",
    name: "Activate",
    headline: "Pick your agents.",
    body: "Choose the AI workers you want — pricing, restock, support, marketing. Toggle any time.",
    points: ["Six agents to choose from", "Turn on or off in a tap", "Approval rules you set"],
  },
  {
    n: "03",
    name: "Run",
    headline: "Watch them run your shop.",
    body: "Agents work 24/7. You approve big moves; they handle everything else.",
    points: ["24/7 autonomous run", "You approve big moves", "Daily brief at 8 am"],
  },
];
---

<section id="how" class="section dark">
  <div class="bg-grid" aria-hidden="true"></div>
  <div class="container">
    <div class="head">
      <span class="eyebrow-dark mono">
        <span class="eyebrow-dot"></span>
        How it works
      </span>
      <h2>From your phone to a working business<br/><span class="serif italic">in under 5 minutes.</span></h2>
    </div>

    <div class="grid">
      {steps.map((s, i) => (
        <article class="card">
          <div class="card-head">
            <span class="num mono">{s.n}</span>
            <span class="name mono">{s.name}</span>
          </div>
          <h3 class="headline">{s.headline}</h3>
          <p class="body">{s.body}</p>
          <ul class="points">
            {s.points.map((p) => (
              <li>
                <span class="tick" aria-hidden="true">
                  <svg width="10" height="10" viewBox="0 0 12 12" fill="none">
                    <path d="M2.5 6.2l2.4 2.3L9.5 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
                <span>{p}</span>
              </li>
            ))}
          </ul>
          {i < steps.length - 1 && <span class="connector" aria-hidden="true"></span>}
        </article>
      ))}
    </div>

    <div class="callout">
      <div class="callout-body">
        <h3>No tech team. No migration. No surprise bills.</h3>
        <p>If you can use WhatsApp, you can run TAR.</p>
      </div>
      <a href="#start" class="callout-btn">
        Start free
        <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .dark {
    position: relative;
    color: #fff;
    overflow: hidden;
    background:
      radial-gradient(900px 480px at 15% 0%, rgba(132, 204, 22, 0.12), transparent 60%),
      radial-gradient(700px 400px at 100% 100%, rgba(132, 204, 22, 0.1), transparent 60%),
      linear-gradient(180deg, #0a2418 0%, #0d2e1f 50%, #103826 100%);
  }
  .bg-grid {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(ellipse 80% 70% at 50% 30%, black 30%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 30%, black 30%, transparent 80%);
  }
  .container { position: relative; z-index: 1; }

  .head {
    margin-bottom: 56px;
    display: flex;
    flex-direction: column;
    gap: 18px;
    max-width: 720px;
  }
  @media (max-width: 720px) { .head { margin-bottom: 40px; } }

  .eyebrow-dark {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.85);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    align-self: flex-start;
  }
  .eyebrow-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: #84cc16;
    box-shadow: 0 0 0 3px rgba(132, 204, 22, 0.25);
  }
  .head h2 { color: #fff; font-size: clamp(1.8rem, 3.6vw, 3rem); }
  .head h2 .italic { color: #d9f99d; font-style: italic; font-weight: 400; }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }
  .card {
    position: relative;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 18px;
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .connector {
    position: absolute;
    top: 50px;
    right: -10px;
    width: 20px;
    height: 1px;
    background: linear-gradient(90deg, rgba(132, 204, 22, 0.5), rgba(132, 204, 22, 0.1));
    z-index: 2;
  }
  .card-head {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-bottom: 18px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }
  .num {
    font-size: 0.7rem;
    color: #84cc16;
    letter-spacing: 0.16em;
    font-weight: 600;
  }
  .name {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.95);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 500;
  }
  .headline {
    font-size: 1.2rem;
    font-weight: 600;
    color: #fff;
    letter-spacing: -0.02em;
    line-height: 1.25;
  }
  .body {
    font-size: 0.94rem;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.6;
  }
  .points {
    list-style: none;
    margin-top: auto;
    padding-top: 20px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .points li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.4;
  }
  .tick {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: rgba(132, 204, 22, 0.18);
    color: #84cc16;
    flex-shrink: 0;
  }

  .callout {
    margin-top: 32px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.04);
    padding: 28px 36px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }
  .callout-body h3 {
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 4px;
    letter-spacing: -0.02em;
    color: #fff;
  }
  .callout-body p {
    color: rgba(255, 255, 255, 0.65);
    font-size: 0.95rem;
  }
  .callout-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    height: 44px;
    padding: 0 22px;
    border-radius: 999px;
    background: #fff;
    color: #0a2418;
    font-size: 0.92rem;
    font-weight: 500;
    white-space: nowrap;
  }

  @media (max-width: 980px) {
    .grid { grid-template-columns: 1fr; gap: 14px; }
    .connector { display: none; }
  }
  @media (max-width: 600px) {
    .card { padding: 28px 24px; }
    .callout { padding: 24px; flex-direction: column; align-items: flex-start; gap: 18px; }
    .callout-btn { width: 100%; }
    .callout-body h3 { font-size: 1.1rem; }
  }
</style>
