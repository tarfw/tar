---
const plans = [
  {
    kind: "Community",
    tag: "Invite-based",
    priceInr: "Free",
    priceUsd: "Free",
    priceSub: "You only pay AI token cost",
    cta: "Apply to join",
    features: [
      "Full TAR app, all 6 AIs",
      "Unlimited stores & products",
      "Pay only for tokens used",
      "Community Slack",
    ],
  },
  {
    kind: "Consumer",
    tag: "For every shop",
    priceInr: "₹500",
    priceUsd: "$6",
    priceSub: "per month",
    cta: "Start free trial",
    features: [
      "Full TAR app, all 6 AIs",
      "5M tokens included monthly",
      { inr: "₹30 per extra 1M tokens", usd: "$0.36 per extra 1M tokens" },
      "Email support",
    ],
  },
];
---

<section id="pricing" class="section pricing">
  <div class="container">
    <div class="rule" aria-hidden="true">
      <span class="rule-num mono">04</span>
      <span class="rule-line"></span>
      <span class="rule-tag mono">
        <span class="rule-dot"></span>
        Pricing
      </span>
    </div>

    <header class="head">
      <h2>
        One price.<br/>
        <span class="serif italic">One unit. Tokens.</span>
      </h2>
      <p class="sub">
        Database reads, API calls, AI work — we count it all as tokens.
        No tier ladders, no per-seat math, no surprise lines on your bill.
      </p>

      <div class="currency" role="tablist" aria-label="Currency">
        <button
          type="button"
          role="tab"
          class="cur-btn is-active"
          aria-selected="true"
          data-cur="inr"
        >INR ₹</button>
        <button
          type="button"
          role="tab"
          class="cur-btn"
          aria-selected="false"
          data-cur="usd"
        >USD $</button>
        <span class="cur-thumb" aria-hidden="true"></span>
      </div>
    </header>

    <div class="grid">
      {plans.map((p) => (
        <div class="plan">
          <span class="kind mono">{p.tag}</span>
          <h3>{p.kind}</h3>

          <div class="price-row">
            <span class="price" data-price-inr={p.priceInr} data-price-usd={p.priceUsd}>{p.priceInr}</span>
            <span class="price-sub">{p.priceSub}</span>
          </div>

          <ul class="feats">
            {p.features.map((f) => {
              const isObj = typeof f === "object";
              return (
                <li>
                  <span class="check" aria-hidden="true">
                    <svg width="10" height="10" viewBox="0 0 12 12" fill="none">
                      <path d="M2.5 6.2l2.4 2.3L9.5 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                  {isObj ? (
                    <span data-feat-inr={(f as any).inr} data-feat-usd={(f as any).usd}>{(f as any).inr}</span>
                  ) : (
                    <span>{f}</span>
                  )}
                </li>
              );
            })}
          </ul>

          <a href="#start" class="pbtn">
            {p.cta}
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      ))}
    </div>

    <p class="token-note">
      <span class="tn-label mono">A token =</span>
      <span>one database read, one API call, or one unit of AI work. Same unit, same bill.</span>
    </p>
  </div>
</section>

<script is:inline>
  (function () {
    const root = document.getElementById("pricing");
    if (!root) return;
    const buttons = root.querySelectorAll(".cur-btn");
    const thumb = root.querySelector(".cur-thumb");
    const prices = root.querySelectorAll("[data-price-inr]");
    const feats = root.querySelectorAll("[data-feat-inr]");

    function moveThumb(activeBtn) {
      if (!thumb || !activeBtn) return;
      const rect = activeBtn.getBoundingClientRect();
      const parentRect = activeBtn.parentElement.getBoundingClientRect();
      thumb.style.width = rect.width + "px";
      thumb.style.transform = "translateX(" + (rect.left - parentRect.left) + "px)";
    }

    function setCurrency(cur) {
      prices.forEach(function (el) {
        el.textContent = el.getAttribute("data-price-" + cur);
      });
      feats.forEach(function (el) {
        el.textContent = el.getAttribute("data-feat-" + cur);
      });
      buttons.forEach(function (b) {
        const on = b.getAttribute("data-cur") === cur;
        b.classList.toggle("is-active", on);
        b.setAttribute("aria-selected", String(on));
        if (on) moveThumb(b);
      });
    }

    buttons.forEach(function (b) {
      b.addEventListener("click", function () {
        setCurrency(b.getAttribute("data-cur"));
      });
    });

    // Initial thumb position (INR default)
    const initial = root.querySelector('.cur-btn[data-cur="inr"]');
    if (initial) {
      // Wait one frame for layout
      requestAnimationFrame(function () { moveThumb(initial); });
      window.addEventListener("resize", function () {
        const active = root.querySelector(".cur-btn.is-active");
        moveThumb(active);
      });
    }
  })();
</script>

<style>
  .pricing { position: relative; }

  /* Section rule strip */
  .rule {
    display: flex;
    align-items: center;
    gap: 18px;
    margin-bottom: 56px;
  }
  .rule-num {
    font-size: 0.78rem;
    color: #4d7c0f;
    letter-spacing: 0.22em;
    font-weight: 600;
    flex-shrink: 0;
  }
  .rule-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg,
      rgba(132, 204, 22, 0.5) 0%,
      rgba(26, 26, 26, 0.14) 30%,
      rgba(26, 26, 26, 0.08) 100%);
  }
  .rule-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    border-radius: 999px;
    background: rgba(132, 204, 22, 0.08);
    border: 1px solid rgba(132, 204, 22, 0.25);
    font-size: 0.68rem;
    color: #4d7c0f;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    flex-shrink: 0;
  }
  .rule-dot {
    width: 5px; height: 5px; border-radius: 50%;
    background: #84cc16;
    box-shadow: 0 0 0 3px rgba(132, 204, 22, 0.2);
  }

  /* Header — centered */
  .head {
    margin: 0 auto 56px;
    display: flex;
    flex-direction: column;
    gap: 18px;
    max-width: 640px;
    text-align: center;
    align-items: center;
  }
  .head h2 {
    font-size: clamp(2rem, 4.2vw, 3.2rem);
    line-height: 1.05;
    letter-spacing: -0.035em;
    margin: 0;
  }
  .head h2 .italic {
    color: #4d7c0f;
    font-style: italic;
    font-weight: 400;
  }
  .sub {
    color: var(--ink-2);
    font-size: 1rem;
    line-height: 1.6;
    max-width: 52ch;
    margin: 0;
  }

  /* Currency toggle */
  .currency {
    position: relative;
    display: inline-flex;
    margin-top: 12px;
    border: 1px solid var(--line-2);
    background: var(--bg);
    padding: 4px;
    gap: 0;
  }
  .cur-btn {
    position: relative;
    z-index: 1;
    padding: 8px 18px;
    font-size: 0.84rem;
    font-weight: 500;
    color: var(--ink-3);
    letter-spacing: -0.005em;
    transition: color 200ms var(--ease);
    background: transparent;
    border: 0;
    font-family: inherit;
    cursor: pointer;
  }
  .cur-btn.is-active { color: #fff; }
  .cur-btn:not(.is-active):hover { color: var(--ink); }
  .cur-thumb {
    position: absolute;
    top: 4px;
    bottom: 4px;
    left: 0;
    width: 0;
    background: var(--ink);
    transition: transform 260ms var(--ease), width 260ms var(--ease);
    z-index: 0;
  }

  /* Flat side-by-side plans, divided by a vertical rule */
  .grid {
    max-width: 880px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-top: 1px solid var(--line-2);
    border-bottom: 1px solid var(--line-2);
  }
  .plan {
    padding: 48px 40px;
    display: flex;
    flex-direction: column;
    gap: 22px;
    text-align: left;
  }
  .plan + .plan {
    border-left: 1px solid var(--line-2);
  }

  .kind {
    font-size: 0.66rem;
    color: #4d7c0f;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-weight: 600;
  }
  .plan h3 {
    font-size: 1.6rem;
    font-weight: 600;
    letter-spacing: -0.025em;
    margin: 0;
    line-height: 1.1;
  }

  .price-row {
    display: flex;
    align-items: baseline;
    gap: 10px;
    flex-wrap: wrap;
    padding-top: 4px;
    padding-bottom: 4px;
  }
  .price {
    font-size: 2.8rem;
    font-weight: 600;
    letter-spacing: -0.04em;
    color: var(--ink);
    line-height: 1;
  }
  .price-sub {
    font-size: 0.88rem;
    color: var(--ink-3);
    line-height: 1.4;
  }

  .feats {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 0;
    margin: 0;
    flex: 1;
  }
  .feats li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.92rem;
    color: var(--ink);
    line-height: 1.45;
  }
  .check {
    width: 14px;
    height: 14px;
    display: grid;
    place-items: center;
    color: #4d7c0f;
    flex-shrink: 0;
    margin-top: 4px;
  }

  /* Flat CTA: text link, not a pill */
  .pbtn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--ink);
    font-size: 0.94rem;
    font-weight: 500;
    border-bottom: 1px solid var(--ink);
    padding-bottom: 6px;
    align-self: flex-start;
    transition: color 200ms var(--ease), border-color 200ms var(--ease), gap 200ms var(--ease);
  }
  .pbtn:hover { color: #4d7c0f; border-color: #4d7c0f; gap: 12px; }

  /* Token note */
  .token-note {
    max-width: 720px;
    margin: 40px auto 0;
    text-align: center;
    color: var(--ink-2);
    font-size: 0.92rem;
    line-height: 1.55;
  }
  .tn-label {
    color: #4d7c0f;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 0.7rem;
    font-weight: 600;
    margin-right: 8px;
  }

  @media (max-width: 720px) {
    .head { margin-bottom: 48px; }
    .grid { grid-template-columns: 1fr; max-width: 460px; }
    .plan { padding: 40px 8px; }
    .plan + .plan {
      border-left: 0;
      border-top: 1px solid var(--line-2);
    }
  }
  @media (max-width: 520px) {
    .price { font-size: 2.4rem; }
  }
</style>
