---
const stories = [
  {
    quote: "We stopped running out of the house special on Sunday lunch. The pricing AI paid for TAR in the first week.",
    name: "Tamizharasi",
    role: "Owner, House Kitchen",
    metric: "+$8.4k",
    metricLabel: "extra/month",
  },
  {
    quote: "I used to spend Sundays on the staff roster. Now I spend them with my kids.",
    name: "Vetrimaaran",
    role: "Owner, Corner Market",
    metric: "6 hours",
    metricLabel: "saved/week",
  },
  {
    quote: "Customers think we have a 24-hour support team. It's just one AI, replying in our voice.",
    name: "Ilavarasi",
    role: "Owner, Studio & Co.",
    metric: "12s",
    metricLabel: "avg reply",
  },
];

const numbers = [
  { v: "1,200+", k: "businesses" },
  { v: "$5.2M", k: "extra revenue" },
  { v: "98%", k: "retention" },
  { v: "4 min", k: "avg setup" },
];
---

<section id="stories" class="section">
  <div class="container">
    <div class="head">
      <span class="eyebrow">Customer stories</span>
      <h2>Quietly running shops<br/><span class="serif italic">around the world.</span></h2>
    </div>

    <div class="numbers">
      {numbers.map((n) => (
        <div class="num">
          <span class="num-v">{n.v}</span>
          <span class="num-k">{n.k}</span>
        </div>
      ))}
    </div>

    <div class="stories">
      {stories.map((s) => (
        <article class="story">
          <blockquote>"{s.quote}"</blockquote>
          <div class="story-foot">
            <div class="who">
              <span class="avatar">{s.name.split(" ").map(n => n[0]).join("").slice(0, 2)}</span>
              <div class="who-text">
                <strong>{s.name}</strong>
                <span>{s.role}</span>
              </div>
            </div>
            <div class="metric">
              <span class="m-v">{s.metric}</span>
              <span class="m-k mono">{s.metricLabel}</span>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .head {
    margin-bottom: 56px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    max-width: 720px;
  }
  @media (max-width: 720px) { .head { margin-bottom: 40px; } }

  .numbers {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: 24px;
  }
  .num {
    background: var(--bg);
    padding: 24px 22px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .num-v {
    font-size: 1.85rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--ink);
    line-height: 1.1;
  }
  .num-k {
    font-size: 0.82rem;
    color: var(--ink-3);
  }

  .stories {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .story {
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 28px;
    background: var(--bg);
    display: flex;
    flex-direction: column;
    gap: 22px;
  }
  blockquote {
    font-size: 1.05rem;
    line-height: 1.5;
    color: var(--ink);
    font-weight: 500;
    letter-spacing: -0.005em;
    flex: 1;
  }
  .story-foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    padding-top: 18px;
    border-top: 1px solid var(--line);
  }
  .who {
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
    flex: 1;
  }
  .avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: var(--bg-tint);
    color: var(--ink);
    font-size: 0.78rem;
    font-weight: 600;
    flex-shrink: 0;
  }
  .who-text { display: flex; flex-direction: column; gap: 1px; min-width: 0; }
  .who-text strong {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--ink);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .who-text span {
    font-size: 0.76rem;
    color: var(--ink-3);
  }
  .metric {
    display: flex;
    flex-direction: column;
    gap: 1px;
    text-align: right;
    flex-shrink: 0;
  }
  .m-v {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--good);
  }
  .m-k {
    font-size: 0.66rem;
    color: var(--ink-3);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  @media (max-width: 980px) {
    .stories { grid-template-columns: 1fr; }
  }
  @media (max-width: 720px) {
    .numbers { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 520px) {
    .num { padding: 20px 18px; }
    .num-v { font-size: 1.55rem; }
    .story { padding: 24px; }
    .story-foot { flex-wrap: wrap; gap: 14px; }
  }
</style>
