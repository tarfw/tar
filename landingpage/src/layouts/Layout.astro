---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "TAR — Run your business on autopilot",
  description = "TAR puts AI to work in your shop, restaurant, or fleet. Set prices, restock, reply to customers, schedule staff — all done while you sleep.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <style is:global>
      :root {
        /* Pure light surfaces */
        --bg: #ffffff;
        --bg-soft: #fbfaf7;
        --bg-tint: #f5f3ee;
        --bg-warm: #f0ece2;

        /* Ink — true black avoided; warm dark grey */
        --ink: #1a1a1a;
        --ink-2: #555555;
        --ink-3: #7a7a7a;
        --ink-4: #a8a8a8;
        --ink-5: #d4d4d4;

        /* Lines */
        --line: #ebe8e1;
        --line-2: #d6d2c8;

        /* Brand accent — used very sparingly */
        --brand: #ff5b1e;
        --brand-soft: #ffe8de;
        --good: #15803d;
        --good-soft: #dcfce7;

        --radius: 10px;
        --radius-lg: 20px;
        --max: 1200px;

        --ease: cubic-bezier(0.22, 1, 0.36, 1);
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html { scroll-behavior: smooth; }

      html,
      body {
        background: var(--bg);
        color: var(--ink);
        font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        font-feature-settings: "ss01", "cv11", "cv02";
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-rendering: optimizeLegibility;
        line-height: 1.5;
        font-size: 16px;
      }

      body { overflow-x: hidden; }

      a { color: inherit; text-decoration: none; }
      button { font: inherit; cursor: pointer; border: 0; background: none; }
      img, svg { display: block; max-width: 100%; }

      .mono {
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-feature-settings: normal;
      }
      .serif {
        font-family: "Instrument Serif", Georgia, serif;
        font-feature-settings: normal;
        font-weight: 400;
      }

      .container {
        max-width: var(--max);
        margin: 0 auto;
        padding: 0 32px;
      }
      @media (max-width: 720px) {
        .container { padding: 0 20px; }
      }
      @media (max-width: 380px) {
        .container { padding: 0 16px; }
      }

      .eyebrow {
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-size: 0.7rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        color: var(--ink-3);
      }

      h1, h2, h3, h4 {
        font-weight: 600;
        letter-spacing: -0.025em;
        color: var(--ink);
        line-height: 1.05;
      }

      h1 { font-size: clamp(2.4rem, 6vw, 4.6rem); letter-spacing: -0.04em; }
      h2 { font-size: clamp(1.8rem, 3.6vw, 3rem); letter-spacing: -0.035em; line-height: 1.08; }
      h3 { font-size: 1.1rem; line-height: 1.25; }

      p { color: var(--ink-2); }

      ::selection { background: var(--ink); color: var(--bg); }

      /* Buttons */
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        height: 48px;
        padding: 0 22px;
        border-radius: 999px;
        font-size: 0.95rem;
        font-weight: 500;
        letter-spacing: -0.005em;
        white-space: nowrap;
        border: 1px solid transparent;
      }
      .btn-primary {
        background: var(--ink);
        color: #fff;
      }
      .btn-secondary {
        background: var(--bg);
        color: var(--ink);
        border-color: var(--line-2);
      }
      .btn-link {
        color: var(--ink);
        height: auto;
        padding: 0;
        background: none;
        border: 0;
        font-weight: 500;
        font-size: 0.95rem;
        border-bottom: 1px solid var(--ink);
        padding-bottom: 2px;
      }

      section { padding: 120px 0; }
      @media (max-width: 880px) { section { padding: 88px 0; } }
      @media (max-width: 520px) { section { padding: 64px 0; } }
    </style>
  </body>
</html>
