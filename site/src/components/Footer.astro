---
---

<footer class="footer">
  <div class="footer__cards">
    <div class="footer__card"></div>
    <div class="footer__card"></div>
    <div class="footer__card"></div>
    <div class="footer__card"></div>
  </div>

  <div class="footer__bottom">
    <div class="footer__socials">
      <a href="#" class="footer__social" aria-label="TikTok">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.34-6.34V8.87a8.16 8.16 0 004.76 1.52V6.94a4.85 4.85 0 01-1-.25z"/></svg>
      </a>
      <a href="#" class="footer__social" aria-label="Instagram">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
      </a>
      <a href="#" class="footer__social" aria-label="X">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
      <a href="#" class="footer__social" aria-label="Square">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><rect x="3" y="3" width="18" height="18" rx="3"/></svg>
      </a>
    </div>

    <div class="footer__links">
      <a href="#">Terms of Service</a>
      <a href="#">Privacy Policy</a>
      <a href="#">Cookie Policy</a>
    </div>

    <p class="footer__disclaimer">
      *TAR is an Everything app that connects users with local services including food delivery, taxi, e-commerce, and more. Service availability and pricing vary by region and are subject to change at TAR's discretion. Features shown are representative and may vary by location.
    </p>
  </div>
</footer>

<style>
  .footer {
    background: #fff;
    padding: 60px 60px 40px;
  }

  .footer__cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 40px;
  }

  .footer__card {
    background: #f0f0f0;
    border-radius: 16px;
    aspect-ratio: 3/4;
  }

  .footer__card:first-child {
    background: #e8e8e8;
  }

  .footer__bottom {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .footer__socials {
    display: flex;
    gap: 16px;
  }

  .footer__social {
    color: #999;
    transition: color 0.2s;
    display: flex;
    align-items: center;
  }

  .footer__social:hover {
    color: #000;
  }

  .footer__links {
    display: flex;
    gap: 24px;
  }

  .footer__links a {
    color: #000;
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    font-size: 14px;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .footer__links a:hover {
    color: #2563eb;
  }

  .footer__disclaimer {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    font-size: 12px;
    line-height: 1.6;
    color: #666;
    max-width: 800px;
  }

  @media (max-width: 768px) {
    .footer {
      padding: 40px 24px 32px;
    }

    .footer__cards {
      grid-template-columns: repeat(2, 1fr);
    }

    .footer__links {
      flex-wrap: wrap;
      gap: 16px;
    }
  }
</style>
