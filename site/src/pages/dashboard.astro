}`
    },
    memory: {
      name: "memory",
      tag: "Semantic Index",
      desc: "Stores raw textual chunks and vector embeddings of all form and matter records. Used for fast hybrid search (combining vector similarity and full-text keyword indexing).",
      fields: [
        { name: "id", type: "TEXT NOT NULL", desc: "The record identifier (form.id or matter.id) that was indexed." },
        { name: "chunk", type: "INTEGER NOT NULL", desc: "Index sequence for long documents split into chunks." },
        { name: "text", type: "TEXT", desc: "The raw text representation index (title, tags, JSON string details)." },
        { name: "embedding", type: "BLOB", desc: "Raw byte buffer containing the floating-point vector dimensions." },
        { name: "meta", type: "TEXT (JSON)", desc: "Copy of core properties (type, scope, owner) to support filtered queries." }
      ],
      json: `{
  "id": "mt_82b9381af",
  "chunk": 0,
  "text": "Task: Review pizza menu | Assignee: John | Priority: high",
  "embedding": [0.0125, -0.0543, 0.1232, "... 384 dimensions"],
  "meta": {
    "table": "matter",
