  // WS Connection Setup
  function connectWebSocket(url) {
    if (ws) {
      ws.close();
    }

    addCollabLog(`Attempting DO WebSocket connection to: ${url}`, "info");
    wsIndicator.className = "indicator-dot connecting";
    wsStatusText.textContent = "Connecting to WorkspaceDO...";

    try {
      ws = new WebSocket(url);

      ws.onopen = () => {
        wsIndicator.className = "indicator-dot connected";
        wsStatusText.textContent = "Connected to Durable Object";
        addCollabLog("Real-time Durable Object sync session established successfully!", "success");
      };

      ws.onmessage = (event) => {
        try {
          const payload = JSON.parse(event.data);
          handleReplicationPayload(payload);
        } catch (e) {
          // fallback string
          if (event.data !== 'pong') {
            addCollabLog(`Incoming message: ${event.data}`, "info");
          }
        }
      };

      ws.onclose = () => {
        wsIndicator.className = "indicator-dot disconnected";
        wsStatusText.textContent = "Disconnected (Using local Broadcast fallback)";
        addCollabLog("DO connection closed. Falling back to local BroadcastChannel.", "warning");
      };

      ws.onerror = () => {
        wsIndicator.className = "indicator-dot disconnected";
        wsStatusText.textContent = "Connection error";
        addCollabLog("Failed to connect to local Wrangler Dev server. Verify 'wrangler dev' is running in tarworker.", "error");
      };

    } catch (err) {
      wsIndicator.className = "indicator-dot disconnected";
      wsStatusText.textContent = "Error initializing WebSockets";
      addCollabLog(`Initialization failed: ${err.message}`, "error");
    }
  }

  wsConnectBtn.addEventListener("click", () => {
