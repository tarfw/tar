  // Handle incoming replication event
  function handleReplicationPayload(payload) {
    if (payload.clientId === myClientId) return;

    if (payload.type === 'cursor') {
      updateRemoteCursor(payload.clientId, payload.x, payload.y, payload.name);
    } else if (payload.type === 'create') {
      // Replicate DB create
      const rec = payload.record;
      const mot = payload.motion;

      // check if exists
      const exists = db.matters.find(m => m.id === rec.id);
      if (!exists) {
        db.matters.push(rec);
        db.motions.push(mot);
        db.save();
        renderLiveTables();
        addCollabLog(`REPLICATED CREATE: Instance ${rec.id} (${rec.data?.title}) synced from teammate.`, "success");
      }
    } else if (payload.type === 'link') {
      const link = payload.link;
      const mot = payload.motion;

      const idx = db.graphs.findIndex(g => g.src === link.src && g.rel === link.rel && g.tgt === link.tgt);
      if (idx === -1) {
        db.graphs.push(link);
        db.motions.push(mot);
        db.save();
        renderLiveTables();
        addCollabLog(`REPLICATED LINK: Graph link (${link.src} - ${link.rel} -> ${link.tgt}) synced.`, "success");
      }
    } else if (payload.type === 'delete') {
      const { targetId, motion } = payload;
      const rec = db.matters.find(m => m.id === targetId);
      if (rec && rec.active === 1) {
        rec.active = 0;
        db.motions.push(motion);
        db.save();
        renderLiveTables();
        addCollabLog(`REPLICATED DELETE: Soft-deleted instance ${targetId}.`, "warning");
      }
    }
  }

