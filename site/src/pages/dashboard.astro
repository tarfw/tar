  "time": "2026-06-27T12:00:00Z"
}`
    },
    motion: {
      name: "motion",
      tag: "Event Log",
      desc: "An append-only transaction ledger. Every single database mutation tool (create, update, delete, link) MUST insert exactly one motion row. This provides audit trails, offline-sync replay logs, and state history.",
      fields: [
        { name: "stream", type: "TEXT", desc: "The target record ID (form.id or matter.id) that was mutated." },
        { name: "seq", type: "INTEGER", desc: "Sequential increment count for this specific stream (1, 2, 3...)." },
        { name: "action", type: "INTEGER", desc: "Opcode identifier (e.g., 1000=INIT/CREATE, 1001=UPDATE, 1002=DELETE)." },
        { name: "phase", type: "INTEGER", desc: "Optional state machine index transition." },
        { name: "delta", type: "REAL", desc: "Numeric field adjustment value." },
        { name: "client_ref", type: "TEXT", desc: "UUID generated by client. Prevents double-writes on network retries (Idempotency)." },
        { name: "data", type: "TEXT (JSON)", desc: "Delta mutation payload, details on what changed, reasons, context." },
        { name: "time", type: "TEXT", desc: "ISO DateTime representation of the mutation event." }
      ],
      json: `{
  "stream": "mt_82b9381af",
