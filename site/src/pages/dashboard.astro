          <th>Relation</th>
          <th>Target</th>
          <th>Weight</th>
          <th>Time</th>
        </tr>
      `;

      const activeGraphs = db.graphs.filter(g => g.active === 1);
      if (activeGraphs.length === 0) {
        body.innerHTML = `<tr><td colspan="5" class="helper-text" style="text-align:center; padding: 24px;">No graph edges active. Link nodes to see relationship indexes!</td></tr>`;
      } else {
        body.innerHTML = "";
        activeGraphs.forEach(g => {
          const row = document.createElement("tr");
          row.innerHTML = `
            <td class="col-name">${g.src}</td>
            <td class="col-type">${g.rel}</td>
            <td class="col-name">${g.tgt}</td>
            <td>${g.weight}</td>
            <td>${new Date(g.time).toLocaleTimeString()}</td>
          `;
          body.appendChild(row);
        });
      }
    } else if (activeLiveTbl === 'motion') {
      head.innerHTML = `
        <tr>
          <th>Stream</th>
          <th>Seq</th>
          <th>Opcode</th>
          <th>Change Details</th>
          <th>Timestamp</th>
        </tr>
      `;

      if (db.motions.length === 0) {
        body.innerHTML = `<tr><td colspan="5" class="helper-text" style="text-align:center; padding: 24px;">No motion logs found. Mutate data to append sync entries.</td></tr>`;
      } else {
        body.innerHTML = "";
        // Show newest logs first
        [...db.motions].reverse().forEach(m => {
          const row = document.createElement("tr");
          let actionLabel = m.action;
          if (m.action === 1000) actionLabel = "CREATE (1000)";
          if (m.action === 1001) actionLabel = "UPDATE (1001)";
          if (m.action === 1002) actionLabel = "DELETE (1002)";
          if (m.action === 1003) actionLabel = "LINK (1003)";

          row.innerHTML = `
            <td class="col-name">${m.stream}</td>
            <td>${m.seq}</td>
            <td class="col-type">${actionLabel}</td>
            <td>${JSON.stringify(m.data)}</td>
            <td>${new Date(m.time).toLocaleTimeString()}</td>
          `;
          body.appendChild(row);
        });
      }
    }
  }

  // Initial connection trigger
  connectWebSocket(wsUrlInput.value.trim());
  renderLiveTables();
</script>
