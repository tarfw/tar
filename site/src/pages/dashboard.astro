  function runSimulation(presetKey) {
    if (activeTimeout) clearTimeout(activeTimeout);
    resetVisualNodes();
    simLog.innerHTML = "";

    const steps = simulationPipelines[presetKey];
    if (!steps) return;

    let stepIndex = 0;

    function executeNextStep() {
      if (stepIndex >= steps.length) return;
      const step = steps[stepIndex];

      const line = document.createElement("span");
      line.className = `console-line ${step.type}`;
      line.textContent = `> ${step.text}`;
      simLog.appendChild(line);
      simLog.scrollTop = simLog.scrollHeight;

      if (step.node) {
        resetVisualNodes();
        if (step.node === "ui") {
          nodeUi.className = "node-state running";
        } else if (step.node === "agent") {
          nodeUi.className = "node-state done";
          nodeAgent.className = "node-state running";
          if (step.conn === "ui-agent") connUiAgent.className = "node-connector active";
          if (step.agentLabel) agentTypeLbl.textContent = step.agentLabel;
        } else if (step.node === "tool") {
          nodeUi.className = "node-state done";
          nodeAgent.className = "node-state done";
          nodeTool.className = "node-state running";
          if (step.conn === "agent-tool") {
            connUiAgent.className = "node-connector active";
            connAgentTool.className = "node-connector active";
          }
          if (step.toolLabel) toolNameLbl.textContent = step.toolLabel;
        } else if (step.node === "db") {
          nodeUi.className = "node-state done";
          nodeAgent.className = "node-state done";
          nodeTool.className = "node-state done";
          nodeDb.className = "node-state running";
          if (step.conn === "tool-db") {
            connUiAgent.className = "node-connector active";
            connAgentTool.className = "node-connector active";
            connToolDb.className = "node-connector active";
          }
        }
      }

      if (step.dbHighlight) {
        const tblCard = document.getElementById(`sim-tbl-${step.dbHighlight}`);
        if (tblCard) {
          tblCard.classList.add("highlight");
          dbCounts[step.dbHighlight]++;
          updateDbLabels();
        }
      }

      if (step.done) {
        resetVisualNodes();
        nodeUi.className = "node-state done";
        nodeAgent.className = "node-state done";
        nodeTool.className = "node-state done";
        nodeDb.className = "node-state done";
        connUiAgent.className = "node-connector active";
        connAgentTool.className = "node-connector active";
        connToolDb.className = "node-connector active";
      }

      stepIndex++;
      activeTimeout = setTimeout(executeNextStep, step.duration);
    }

    executeNextStep();
  }

