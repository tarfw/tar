</style>

<script is:inline>
  // ==========================================
  // CLIENT DATABASE ENGINE (5 TABLES IN LOCALSTORAGE)
  // ==========================================
  class LocalDB {
    constructor() {
      this.load();
    }

    load() {
      this.forms = JSON.parse(localStorage.getItem('tar_forms') || '[]');
      this.matters = JSON.parse(localStorage.getItem('tar_matters') || '[]');
      this.motions = JSON.parse(localStorage.getItem('tar_motions') || '[]');
      this.graphs = JSON.parse(localStorage.getItem('tar_graphs') || '[]');
      this.memories = JSON.parse(localStorage.getItem('tar_memories') || '[]');

      // Seed default blueprints if empty
      if (this.forms.length === 0) {
        this.forms = [
          {
            id: 'form_task',
            code: 'task',
            type: 'schema',
            scope: 'g',
            title: 'Task Blueprint',
            data: { schema: { title: 'string|required', assignee: 'string', state: 'string' } },
            active: 1,
            time: new Date().toISOString()
          },
          {
            id: 'form_order',
            code: 'order',
            type: 'schema',
            scope: 'g',
            title: 'Order Blueprint',
            data: { schema: { item: 'string', value: 'number', state: 'string' } },
            active: 1,
            time: new Date().toISOString()
          }
        ];
        this.save();
      }
    }

    save() {
      localStorage.setItem('tar_forms', JSON.stringify(this.forms));
      localStorage.setItem('tar_matters', JSON.stringify(this.matters));
      localStorage.setItem('tar_motions', JSON.stringify(this.motions));
      localStorage.setItem('tar_graphs', JSON.stringify(this.graphs));
      localStorage.setItem('tar_memories', JSON.stringify(this.memories));
    }

    // CREATE
    create(table, record) {
      record.id = record.id || (table === 'form' ? 'fm_' : 'mt_') + Math.random().toString(36).substring(2, 10);
      record.active = 1;
      record.time = record.time || new Date().toISOString();

      if (table === 'form') {
        this.forms.push(record);
      } else {
        this.matters.push(record);
        this.memories.push({
          id: record.id,
          chunk: 0,
          text: `Type: ${record.type} | Title: ${record.data?.title || ''} | Owner: ${record.owner || ''}`,
          meta: { table: 'matter', type: record.type, scope: record.scope }
        });
      }

      const seq = this.motions.filter(m => m.stream === record.id).length + 1;
      const motionRecord = {
        stream: record.id,
        seq,
        action: 1000,
        data: { event: 'created', table, type: record.type, label: record.data?.title || record.title },
        time: new Date().toISOString()
      };
      this.motions.push(motionRecord);

      this.save();
      return { record, motionRecord };
    }

    // UPDATE
    update(table, id, dataPatch) {
      let record = null;
      if (table === 'form') {
        record = this.forms.find(f => f.id === id);
      } else {
        record = this.matters.find(m => m.id === id);
      }

      if (!record) return null;

      record.data = { ...record.data, ...dataPatch };
      record.time = new Date().toISOString();

      const seq = this.motions.filter(m => m.stream === id).length + 1;
      const motionRecord = {
        stream: id,
        seq,
        action: 1001,
        data: { event: 'updated', table, patch: dataPatch },
        time: new Date().toISOString()
      };
      this.motions.push(motionRecord);

      // Update search index text
      const idx = this.memories.findIndex(m => m.id === id);
      if (idx !== -1) {
        this.memories[idx].text = `Type: ${record.type} | Title: ${record.data?.title || ''} | Owner: ${record.owner || ''}`;
      }

      this.save();
      return { record, motionRecord };
    }

    // DELETE
    delete(table, id) {
      let record = null;
      if (table === 'form') {
        record = this.forms.find(f => f.id === id);
      } else {
        record = this.matters.find(m => m.id === id);
      }

      if (!record) return null;

      record.active = 0;
      record.time = new Date().toISOString();

      // Cascade graph deactivation
      this.graphs.forEach(g => {
        if (g.src === id || g.tgt === id) {
          g.active = 0;
        }
      });

      const seq = this.motions.filter(m => m.stream === id).length + 1;
      const motionRecord = {
        stream: id,
        seq,
        action: 1002,
        data: { event: 'deleted', table },
        time: new Date().toISOString()
      };
      this.motions.push(motionRecord);

      this.save();
      return { record, motionRecord };
    }

    // LINK
    link(src, rel, tgt, weight = 1.0) {
      const linkRecord = { src, rel, tgt, weight, active: 1, time: new Date().toISOString() };
      const idx = this.graphs.findIndex(g => g.src === src && g.rel === rel && g.tgt === tgt);
      
      if (idx !== -1) {
        this.graphs[idx] = linkRecord;
      } else {
        this.graphs.push(linkRecord);
      }

      const seq = this.motions.filter(m => m.stream === src).length + 1;
      const motionRecord = {
        stream: src,
        seq,
        action: 1003,
        data: { event: 'linked', relation: rel, target: tgt },
        time: new Date().toISOString()
      };
      this.motions.push(motionRecord);

      this.save();
      return { link: linkRecord, motionRecord };
    }

    // SEARCH
    search(query) {
      if (!query) return [];
      const q = query.toLowerCase();
      const results = [];

      this.memories.forEach(mem => {
        const text = mem.text.toLowerCase();
        if (text.includes(q)) {
          const record = this.matters.find(m => m.id === mem.id && m.active === 1);
          if (record) {
            const score = 0.5 + (q.length / text.length) * 0.5;
            results.push({ record, score: parseFloat(score.toFixed(2)) });
          }
        }
      });

      return results.sort((a, b) => b.score - a.score);
    }
  }

  // Init local database
  const db = new LocalDB();

  // ==========================================
  // TAB SYSTEM CONTROLLER
  // ==========================================
  const tabs = document.querySelectorAll(".nav-tab");
  const panes = document.querySelectorAll(".tab-pane");

  tabs.forEach(tab => {
    tab.addEventListener("click", () => {
      tabs.forEach(t => t.classList.remove("active"));
      panes.forEach(p => p.classList.remove("active"));

      tab.classList.add("active");
      const target = document.getElementById(`tab-${tab.dataset.tab}`);
      if (target) target.classList.add("active");

      // Auto trigger live updates when hitting realtime tab
      if (tab.dataset.tab === 'realtime') {
        renderLiveTables();
      }
    });
  });

  // ==========================================
  // STATIC DB TAB DETAILS RENDER
  // ==========================================
  const dbData = {
    form: {
      name: "form",
      tag: "Blueprint",
      desc: "Defines blueprints, templates, state machines, agents, flow charts, forms, and plugin integrations. Changing app logic is simply inserting/modifying records in this table.",
      fields: [
        { name: "id", type: "TEXT PRIMARY KEY", desc: "Unique record identifier (e.g. form_create_task, agent_router)." },
        { name: "code", type: "TEXT UNIQUE", desc: "Short code representation for easy lookup." },
        { name: "type", type: "TEXT", desc: "Categorization type: 'schema', 'agent', 'flow', 'form'." },
        { name: "scope", type: "TEXT", desc: "Data access scope: 'p' (personal), 't:id' (workspace), 's:id' (store), 'g' (global)." },
        { name: "owner", type: "TEXT", desc: "The creator/owner identity (e.g. user_id)." },
        { name: "title", type: "TEXT", desc: "Human readable display name." },
        { name: "public", type: "INTEGER", desc: "Flags if the blueprint is shared/clonable (1 = true, 0 = false)." },
        { name: "active", type: "INTEGER", desc: "Soft deletion indicator (1 = active, 0 = deleted)." },
        { name: "data", type: "TEXT (JSON)", desc: "Main config body. Stores fields, validators, states, transitions, prompt presets." },
        { name: "time", type: "TEXT", desc: "Timestamp when record was created or updated." }
      ],
      json: `{
  "id": "form_task_blueprint",
  "code": "task",
  "type": "schema",
  "scope": "g",
  "title": "Task Blueprint",
  "data": {
    "schema": {
      "title": "string|required",
      "assignee": "string",
      "priority": "string",
      "due": "string"
    },
    "states": ["pending", "in_progress", "completed", "cancelled"],
    "transitions": [
      { "from": "pending", "to": "in_progress", "opcode": 1001 },
      { "from": "in_progress", "to": "completed", "opcode": 1002 },
      { "from": "*", "to": "cancelled", "opcode": 1003 }
    ]
  }
}`
    },
    matter: {
      name: "matter",
      tag: "Instance",
      desc: "Stores physical data records. Any actual transaction, lead, issue, order, invoice, profile, or ticket is a row in this table. Its structure conforms to the form blueprint schema.",
      fields: [
        { name: "id", type: "TEXT PRIMARY KEY", desc: "Unique physical entity ID (e.g. mt_92a831...)." },
        { name: "form", type: "TEXT", desc: "Foreign key reference to the form.id that defines this record's schema." },
        { name: "type", type: "TEXT", desc: "Materialized duplicate of form.type for high-speed indexing." },
        { name: "scope", type: "TEXT", desc: "The tenant database partition key ('p', 't:12', 's:32')." },
        { name: "qty", type: "REAL", desc: "Numeric quantity helper (e.g. hours logged, product count)." },
        { name: "value", type: "REAL", desc: "Financial currency value helper (e.g. payment total, quote price)." },
        { name: "variant", type: "INTEGER", desc: "Variant classification integer (multi-purpose)." },
        { name: "mark", type: "INTEGER", desc: "Sub-priority classification index." },
        { name: "geo", type: "TEXT", desc: "Geo location coordinates: 'latitude,longitude' (for geo-searching)." },
        { name: "start", type: "TEXT", desc: "ISO DateTime representation of start time/due date." },
        { name: "end", type: "TEXT", desc: "ISO DateTime representation of end time." },
        { name: "active", type: "INTEGER", desc: "Soft-delete flag (1 = active, 0 = inactive)." },
        { name: "data", type: "TEXT (JSON)", desc: "Flexible key-value payload containing actual fields (title, desc, status)." },
        { name: "owner", type: "TEXT", desc: "The creator/owner identity (for ACL checks)." },
        { name: "time", type: "TEXT", desc: "ISO DateTime of the record." }
      ],
      json: `{
  "id": "mt_82b9381af",
  "form": "form_task_blueprint",
  "type": "task",
  "scope": "t:workspace_alpha",
  "qty": null,
  "value": null,
  "geo": null,
  "active": 1,
  "data": {
    "title": "Review pizza menu",
    "assignee": "John",
    "priority": "high",
    "state": "pending"
  },
