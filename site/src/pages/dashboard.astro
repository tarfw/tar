        { name: "weight", type: "REAL DEFAULT 1.0", desc: "Relevance score, sequence order index, or match strength." },
        { name: "active", type: "INTEGER DEFAULT 1", desc: "Active flag. Soft deletes in parent records cascade here (active=0)." },
        { name: "time", type: "TEXT", desc: "ISO creation timestamp." }
      ],
      json: `{
