    "owner": "usr_dev_1"
  }
}`
    }
  };

  function selectDbTable(tableName) {
    const data = dbData[tableName];
    const el = document.getElementById("db-details-content");
    if (!el || !data) return;

    let fieldsHtml = "";
    data.fields.forEach(f => {
      fieldsHtml += `
        <tr>
          <td class="col-name">${f.name}</td>
          <td class="col-type">${f.type}</td>
          <td>${f.desc}</td>
        </tr>
      `;
    });

    el.innerHTML = `
      <div class="db-detail-header">
        <div class="db-detail-title-row">
          <h3>Table: ${data.name}</h3>
          <span class="badge ${data.name === 'form' ? 'cyan' : data.name === 'matter' ? 'blue' : data.name === 'motion' ? 'purple' : data.name === 'graph' ? 'green' : 'yellow'}">${data.tag}</span>
        </div>
        <p class="db-detail-desc">${data.desc}</p>
      </div>
      <h4>Database Schema Definition:</h4>
      <table class="schema-table">
        <thead>
          <tr>
            <th>Column</th>
            <th>Type</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
          ${fieldsHtml}
        </tbody>
      </table>
      <h4>Example Record (JSON representation):</h4>
      <pre class="json-data"><code>${data.json}</code></pre>
    `;
  }

  const dbItems = document.querySelectorAll(".db-nav-item");
  dbItems.forEach(item => {
    item.addEventListener("click", () => {
      dbItems.forEach(i => i.classList.remove("active"));
      item.classList.add("active");
      selectDbTable(item.dataset.table);
    });
  });

  selectDbTable("form");

  // ==========================================
  // STATIC TOOLS TAB DETAILS RENDER
  // ==========================================
  const toolsData = {
    create: {
      name: "create",
      desc: "Inserts a form or matter record into local SQLite, pushes it to WebSocket queues for Cloud DO replication, links relationships in the graph table, writes a motion log, and indexes vector embeddings. All of these steps are executed atomically inside a database transaction.",
      sql: `BEGIN TRANSACTION;
-- 1. Insert actual record
INSERT INTO matter (id, form, type, scope, qty, value, active, variant, mark, geo, start, end, data, owner, time)
VALUES ('mt_82b9381af', 'form_task_blueprint', 'task', 't:alpha', NULL, NULL, 1, NULL, 0, NULL, NULL, NULL, '{"title":"Review menu","assignee":"John"}', 'usr_dev_1', '2026-06-27T12:00:00Z');

-- 2. Insert graph relationships
INSERT OR REPLACE INTO graph (src, rel, tgt, weight, active, time)
VALUES ('mt_82b9381af', 'assigned_to', 'usr_john_45', 1.0, 1, '2026-06-27T12:00:00Z');

-- 3. Insert append-only event log
INSERT INTO motion (stream, seq, action, phase, delta, client_ref, data, time)
VALUES ('mt_82b9381af', 1, 1000, NULL, NULL, 'client-ref-uuid', '{"event":"created","table":"matter","type":"task"}', '2026-06-27T12:00:00Z');

-- 4. Push vector to memory table
INSERT INTO memory (id, chunk, text, embedding, meta)
VALUES ('mt_82b9381af', 0, 'Task: Review menu...', [vector_bytes], '{"table":"matter","scope":"t:alpha"}');
COMMIT;`,
      rules: [
        "Checks client_ref to guarantee idempotency. If client_ref matches a previous motion log, it returns the existing record instead of recreating it.",
        "Validates input payload fields against JSON Schema from the corresponding form record.",
        "Ensures user has ACL write permissions (requireCanCreate)."
      ]
    },
    read: {
      name: "read",
      desc: "Fetches rows with query parameters. Automatically supports SQL query generation, JSON path extraction, table joins, multi-hop recursive graph queries, and paginated sorting.",
      sql: `-- Basic SQL translation for read command
SELECT *, json_extract(data, '$.title') AS title_extracted FROM matter
WHERE scope = 't:alpha'
  AND type = 'task'
  AND active = 1
ORDER BY time DESC
LIMIT 50 OFFSET 0;

-- Complex graph traversal read (fetch all people assigned to tasks in a project)
WITH RECURSIVE traversal(src, rel, tgt, depth) AS (
  SELECT src, rel, tgt, 1 FROM graph WHERE src = 'project_delta_9' AND active = 1
  UNION ALL
  SELECT g.src, g.rel, g.tgt, t.depth + 1 FROM graph g
  JOIN traversal t ON g.src = t.tgt
  WHERE t.depth < 3 AND g.active = 1
)
SELECT * FROM matter WHERE id IN (SELECT tgt FROM traversal WHERE rel = 'assigned_to');`,
      rules: [
        "Applies read ACL filtering (requireCanRead). Disallows reading if the caller does not have team or personal credentials matching the scope.",
        "Decrypts/formats data JSON blocks back to JavaScript objects."
      ]
    },
    update: {
      name: "update",
      desc: "Updates properties of a record. It performs copy-on-write deep merges of the data JSON payload, validates state machine transitions defined on the form template, and logs a motion log detailing the mutated fields.",
      sql: `BEGIN TRANSACTION;
-- 1. Get current state and validate transition (e.g. pending -> completed)
SELECT data FROM matter WHERE id = 'mt_82b9381af';

-- 2. Update record and merge JSON data
UPDATE matter SET
  data = '{"title":"Review menu","assignee":"John","state":"completed"}',
  time = '2026-06-27T12:05:00Z'
WHERE id = 'mt_82b9381af' AND scope = 't:alpha';

-- 3. Write motion log with updated fields list
INSERT INTO motion (stream, seq, action, phase, delta, client_ref, data, time)
VALUES ('mt_82b9381af', 2, 1002, 2, NULL, 'uuid-update', '{"reason":"completed task","changed":["state"]}', '2026-06-27T12:05:00Z');
COMMIT;`,
      rules: [
        "Validates state machine index phase (e.g., preventing transitions directly from 'pending' to 'delivered' without being 'confirmed').",
        "Triggers vector re-embedding in background."
      ]
    },
    delete: {
      name: "delete",
      desc: "Flags a record as deleted (active=0). Does not delete records from the database except for personal 'p:' scope data. If cascade=true, it automatically deactivates all graph edges connected to the deleted record.",
      sql: `BEGIN TRANSACTION;
-- 1. Soft delete the matter row
UPDATE matter SET active = 0 WHERE id = 'mt_82b9381af' AND scope = 't:alpha';

-- 2. Cascade deactivate graph connections
UPDATE graph SET active = 0 WHERE src = 'mt_82b9381af' OR tgt = 'mt_82b9381af';

-- 3. Log deletion motion
INSERT INTO motion (stream, seq, action, client_ref, data, time)
VALUES ('mt_82b9381af', 3, 1003, NULL, '{"event":"deleted","mode":"soft"}', '2026-06-27T12:10:00Z');
COMMIT;`,
      rules: [
        "Verifies owner authorization to delete (requireCanDelete).",
        "Removes embeddings index from vector storage."
      ]
    },
    link: {
      name: "link",
      desc: "Upserts a relationship link in the graph table between two node IDs, attributing it with a connection strength weight.",
      sql: `INSERT OR REPLACE INTO graph (src, rel, tgt, weight, active, time)
