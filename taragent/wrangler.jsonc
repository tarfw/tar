// wrangler.jsonc — TAR Universal Commerce Agent
{
  "name": "tar-agent",
  "main": "src/index.ts",
  "compatibility_date": "2025-03-07",
  "compatibility_flags": ["nodejs_compat"],

  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
  },

  // 10 Durable Object bindings — one per commerce agent
  "durable_objects": {
    "bindings": [
      { "name": "UserAgent", "class_name": "UserAgent" },
      { "name": "StoreAgent", "class_name": "StoreAgent" },
      { "name": "OrderAgent", "class_name": "OrderAgent" },
      { "name": "DriverAgent", "class_name": "DriverAgent" },
      { "name": "InventoryAgent", "class_name": "InventoryAgent" },
      { "name": "CatalogAgent", "class_name": "CatalogAgent" },
      { "name": "FleetAgent", "class_name": "FleetAgent" },
      { "name": "ChatAgent", "class_name": "ChatAgent" },
      { "name": "SearchAgent", "class_name": "SearchAgent" },
      { "name": "TaskAgent", "class_name": "TaskAgent" },
    ],
  },

  // SQLite state is required for all 10 agent classes
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "UserAgent",
        "StoreAgent",
        "InventoryAgent",
        "CatalogAgent",
        "FleetAgent",
        "ChatAgent",
        "SearchAgent",
        "TaskAgent",
      ],
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["OrderAgent", "DriverAgent"],
    },
  ],

  "vars": {
    "GROQ_BASE_URL": "https://api.groq.com/openai/v1",
    "GROQ_MODEL": "openai/gpt-oss-20b",
    "TURSO_URL": "libsql://tarapp-tarframework.aws-eu-west-1.turso.io",
    "TELEGRAM_BOT_USERNAME": "TarBot",
    "WHATSAPP_PHONE_NUMBER_ID": "",
    "WHATSAPP_VERIFY_TOKEN": "tar_verify_token",
    "SLACK_BOT_TOKEN": "",
    "SLACK_SIGNING_SECRET": "",
  },

  // Secrets — set via `wrangler secret put`:
  //   GROQ_API_KEY
  //   TURSO_AUTH_TOKEN
  //   TELEGRAM_BOT_TOKEN
  //   WHATSAPP_ACCESS_TOKEN
  //   SLACK_BOT_TOKEN
  //   SLACK_SIGNING_SECRET
}
