{
  "expo": {
    "name": "tarai",
    "slug": "tarai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tarai",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "icon": "./assets/expo.icon",
      "supportsTablet": true
    },
    "android": {
      "package": "com.tarai.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "androidClientId": "291840005173-ojtlidsa0chte2spk7ruv80o5lo11dsd.apps.googleusercontent.com",
          "iosUrlScheme": "com.googleusercontent.apps.291840005173-ggf87u7atopdohatin502o1q9gmsceq5",
          "webClientId": "291840005173-ggf87u7atopdohatin502o1q9gmsceq5.apps.googleusercontent.com",
          "scopes": [
            "profile",
            "email"
          ]
        }
      ],
      "expo-secure-store",
      "expo-file-system",
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1cb02c4c-faa5-4c1e-9a31-9ae43ddee99d"
      }
    }
  }
}
