{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": false,
    "noEmit": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": []
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "src/cloudflare.ts",
    "src/lib/acl.ts",
    "src/lib/tools.ts",
    "src/lib/vectorStore.ts",
    "src/lib/textSplitter.ts",
    "src/workflows/**"
  ]
}
